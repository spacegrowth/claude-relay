#!/usr/bin/env python3
"""
relay — delegate work packets from a Fable lead session to executor sessions in their own
iTerm tabs, reusing a live session for related follow-up packets instead of spawning a fresh
one each time.

Commands:
  relay spawn <worktree> <topic> <packet.md> [--model NAME] [--name LABEL]
  relay send  <session_id> <packet.md>
  relay check [<session_id> | --all] [--json]
  relay status [session_id] [--statusline]    # read-only, statusline-safe one-liner; never writes
  relay list [--lead <session_id> | --all] [--json]
  relay report <session_id> [--packet N]      # print an executor's report, framed in green
  relay close <session_id> [--supersede <new_session_id>]
  relay close --self <session_id>            # step down from lead mode
  relay stop <session_id>                    # step down from lead mode (alias for close --self)
  relay lead-start <session_id> [--model N]   # mark this session a lead (from /relay:mode)
  relay adopt <session_id> [--force]          # re-point an executor's auto-wake ownership to this lead
  relay route retain "<reason>" --session <session_id>   # open the retain grace window
  relay handoff <handoff.md> [--project NAME] [--model NAME]  # succeed this lead with a pre-armed fresh one
  relay close-predecessor                    # close the outgoing lead's tab after a handoff, on user go
  relay nudge-lead <lead> "<message>"        # type a message into a LEAD's own tab; always sends
"""
import argparse
import json
import os
import re
import shlex
import shutil
import signal
import subprocess
import sys
import time
import urllib.parse
import uuid
from pathlib import Path

sys.path.insert(0, os.path.join(os.path.dirname(os.path.realpath(__file__)), "..", "scripts"))
sys.path.insert(0, os.path.join(os.path.dirname(os.path.realpath(__file__)), "..", "lib"))
import backend
import diff_render
import lead_guard
import iterm as iterm_backend  # the REAL scripts/iterm.py module, always -- distinct from the
                               # `iterm` name below (this invocation's SELECTED backend, which can
                               # resolve to terminal_app). _background_label_loop is iTerm-specific
                               # by design (see its docstring) and must not follow that selection.

# The terminal backend for THIS invocation ($RELAY_TERMINAL > config > $TERM_PROGRAM; see
# scripts/backend.py). Named `iterm` because that was the only backend for most of relay's life —
# every call site (and the test suite's mock.patch.object(relay.iterm, …)) addresses it this way.
iterm = backend.select()


def term_backend(s):
    """Backend module for an EXISTING session — honors the backend recorded at its spawn (a session
    opened in Terminal.app must keep being addressed there even if relay now runs under iTerm).
    Pre-backend session records (no field) use this invocation's selected backend."""
    return backend.by_name((s or {}).get("backend")) or iterm

STATE_ROOT = Path.home() / ".relay-tasks"
LEDGER = STATE_ROOT / "sessions.jsonl"

# Default only — kept independently settable from poll_seconds (1800) via config's
# stall_threshold_seconds (lead_guard.LEAD_DEFAULTS) so the executor stall-flip and the idle-lead
# poller's timeout no longer fire on one shared clock (wake-watch design §6, §2.2's "two numeric
# coincidences"). _stall_threshold_seconds() is the one place that resolves the live value; this
# constant is only the fallback when no config is readable.
STALL_THRESHOLD_SECONDS = 45 * 60


def _stall_threshold_seconds():
    try:
        return int(lead_guard.load_config(STATE_ROOT).get("stall_threshold_seconds", STALL_THRESHOLD_SECONDS))
    except Exception:
        return STALL_THRESHOLD_SECONDS

RELAY_BIN = str(Path(__file__).resolve())

# The status a session carries when relay KNOWS claude never came up for it (backlog §12, #20/#21):
# spawn got neither of its two launch signals back even after a retry, or a resume's relaunched
# process was already gone a grace window later. Deliberately NOT `busy` (a lie — nothing is
# working) and NOT `dead` (which reads as "it ran and then died", and hides the fact that the
# pinned conversation id was never registered with Claude Code, so `relay resume` can never work).
# `relay restart` is the recovery: it mints a fresh conversation id in a fresh tab.
LAUNCH_FAILED = "launch-failed"

# How long a freshly (re)launched claude must survive before we'll call the launch real. The shell
# writes the pidfile BEFORE exec'ing claude, so a pid we just read proves only that the shell ran —
# `claude --resume <id-that-was-never-created>` exits within milliseconds ("A session ended very
# soon after starting"), which is how resume came to print "resumed … pid N" for an already-gone
# pid. Only the healthy path actually waits this out: the probe returns the moment the pid is gone.
LAUNCH_GRACE_SECONDS = 3.0

# `--settings` timeout for the executor escalation Stop hook (wake-watch design §9) — the hook is a
# plain synchronous push now (no asyncRewake, nothing long-running to host), so this is just a
# safety margin above its few-hundred-ms of work, not a budget for grace/backoff sleeping.
EXECUTOR_ESCALATION_TIMEOUT_SECONDS = 30


def _maybe_escalation_settings_file(exec_name):
    """The `--settings` file to launch an executor with (arms hooks/executor_escalation.py), or
    None if the config kill-switch is off or the settings file couldn't be written — a write
    failure must degrade to spawning WITHOUT escalation armed, never block the spawn itself.

    `exec_name` (the RELAY name) is baked into the hook command: the hook can't derive its own
    identity from Claude Code's payload, which carries the Claude session id while relay files
    state under the relay name. See lead_guard.build_escalation_settings."""
    cfg = lead_guard.load_config(STATE_ROOT)
    if not cfg.get("executor_escalation", True):
        return None
    return lead_guard.write_escalation_settings(STATE_ROOT, _plugin_root(), exec_name,
                                                timeout=EXECUTOR_ESCALATION_TIMEOUT_SECONDS)

TEMPLATE_FOOTER = """

---
(relay — do not remove or reword this section)

GATES
- STAGE, NEVER COMMIT. Leave your work staged (git add), uncommitted. The lead reviews the
  staged diff and commits it. Do not run `git commit` yourself.
- ONE LOGICAL DELIVERABLE. This packet is scoped to a single atomic, reviewable-in-one-sitting
  change. If you find the work actually splits into unrelated concerns, stop and report that
  instead of doing both.
- TREAT THIS PACKET COLD. Re-read every file you touch; trust no memory of prior packets or
  conversations — earlier state may have been landed, reverted, or superseded since this packet
  was written. If the packet text alone wasn't enough to complete the work, say so explicitly in
  your report.
- STOP AND REPORT, NEVER ASK IN THE TAB. If a step cannot be executed against currently
  deployed/committed/applied state (needs a restart, un-applied DDL, an unpulled checkout, an
  unlanded commit) OR needs any judgement call this packet can't resolve, STOP at that point.
  Write a partial report naming the blocker and end your turn — never improvise the step, and
  never raise an interactive question for it. The report → lead-wake channel is your only
  escalation path; the human is never the recipient of an executor's question.
- STAY IDLE AFTER REPORTING. After you write your report, remain idle — do NOT exit, and do NOT
  commit (the lead reviews and commits). The lead may reuse this session for a follow-up packet, and
  will `relay close` it when done. Closing the tab yourself throws away the reusable context.
  After running the self-diff step, end your final turn with EXACTLY this one line, nothing after it:
      ✅ [relay] — staged + report written — diff: {diff_url} — idle, awaiting the lead's review.

REPORT FORMAT
Before you stop, write your full report to {report_path} (not just stdout/chat).
- THE VERY FIRST LINE of the report must be ONE PLAIN SENTENCE stating the outcome — what was
  built/fixed and its verification state. No heading marker, no "Report:" prefix, no keyword
  label — this exact line becomes the desktop notification and the lead's wake message, so write
  it for a human glancing at a banner, e.g.:
      Split-pane layout works behind a config flag; 9 new tests, suite green, staged.
- Immediately after that first line, a REQUIRED TL;DR block — the lead reads this always, the
  full report only when a risk flag is up, so these four fields must be present verbatim and in
  this order:
      Status: clean / clean-with-caveats / blocked / partial
      Risk flags: <failing tests, weakened tests, scope creep, anything touching core
          logic/ledgers/parity tests> — or exactly `Risk flags: none` when there are none.
      UNVERIFIED: <every claim you did not verify live — ran but didn't observe, assumed env,
          untested path> — or exactly `UNVERIFIED: none` when truly none. This line is MANDATORY
          and must NEVER be omitted, even when none — its absence must read as malformed, not as
          "nothing to report."
      Changed: <one-line what-changed summary>
Then include the full detail:
- What changed (file:line for each substantive change).
- What you verified, and with which command/result.
- Acceptance-criteria outcomes, if the packet listed any.
- Anything you could NOT verify — name it explicitly as UNVERIFIED (same claims as the TL;DR's
  UNVERIFIED line, expanded). An honest gap is fine; a hidden one is not.
- Confirmation that your changes are staged (not committed) and ready for the lead to review.

AFTER writing your report, run:
  {diff_cmd}
(generates your staged-diff review page; do not open it, do not attach it anywhere — just run it once)
"""

AFTERCARE_FOOTER = """

---
(relay — SUCCESSOR AFTERCARE; do not remove)
You were pre-armed by relay handoff under pinned session id {successor_sid}.
1. VERIFY ARMING once you've settled: run /relay:mode — idempotent if your session id matches the
   pin; it arms your REAL id if the pin didn't hold. If your id differs from {successor_sid}, also
   run: relay stop {successor_sid}   (clears the orphaned pre-armed marker).
2. THE PREDECESSOR'S TAB: its identity is recorded in your marker. ASK the user whether to close
   it; on their go run: relay close-predecessor . Never close it unasked.
3. Your first send/resume of an inherited executor adopts it automatically.
"""


# Matches an aftercare section previously appended by build_handoff_copy, from its leading "---"
# through the end of the string (it is always the last thing in the file). Strips a stale one
# before appending a fresh one, so re-handoff of an already-processed doc (#19 — e.g. the source
# passed to `relay handoff` is itself a prior successor's relay-owned copy) can never stack a
# second section instead of replacing the first.
AFTERCARE_RE = re.compile(r"\n*---\n\(relay — SUCCESSOR AFTERCARE.*\Z", re.DOTALL)


DISCIPLINE_MARKER_RE = re.compile(r"\[[a-z-]+\]")


def dropped_discipline_markers(predecessor_body, new_body):
    """d4 — the handoff-time linter half. `[discipline]` markers (e.g. `[ops-not-lead-work]`) that
    appear in the doc the outgoing lead itself inherited must survive into the doc it hands to its
    OWN successor, verbatim — see §10's incident, where one such marker silently dropped between
    handoffs and the successor re-derived its absence the hard way. Returns the markers present in
    `predecessor_body` but missing from `new_body`, in first-seen order, deduped; empty if none
    dropped (including when there's no predecessor doc to compare against)."""
    if not predecessor_body:
        return []
    seen = dict.fromkeys(DISCIPLINE_MARKER_RE.findall(predecessor_body))
    return [m for m in seen if m not in new_body]


def build_handoff_copy(body, successor_sid):
    """The relay-owned handoff.md a successor actually reads: the user's authored content
    unmodified, plus an appended SUCCESSOR AFTERCARE section — same relationship as
    build_packet/TEMPLATE_FOOTER. Written under the successor's OWN lead dir so the user's source
    file is never touched, and the seed prompt can stay a short pointer at this copy instead of
    inlining the aftercare (see cmd_handoff's truncation postmortem). Idempotent (#19): any
    aftercare section already present in `body` (from a prior handoff of this same doc) is
    stripped before the fresh one is appended, so re-handoff never stacks a second section."""
    return AFTERCARE_RE.sub("", body.rstrip()).rstrip() + AFTERCARE_FOOTER.format(successor_sid=successor_sid)


def path_to_file_url(path):
    """Convert an absolute path to a file:// URL with proper encoding."""
    return f"file://{urllib.parse.quote(str(path), safe='/')}"


def slugify(text):
    s = re.sub(r"[^a-z0-9]+", "-", text.lower()).strip("-")
    return s or "task"


def now():
    return time.strftime("%Y-%m-%dT%H:%M:%S")


def _plugin_root():
    """The plugin dir this bin/relay lives in (parent of bin/). Under an installed plugin this is
    .../plugins/cache/claude-relay/relay/<version>/ — the SAME ${CLAUDE_PLUGIN_ROOT} the session's
    hooks run from, since /relay:mode invokes us as ${CLAUDE_PLUGIN_ROOT}/bin/relay. That's the whole
    reason stamping works: the version WE read here is exactly the version whose Stop hook will fire
    for this session (see cmd_lead_start / wake_hook_state)."""
    return Path(os.path.dirname(os.path.realpath(__file__))).parent


def plugin_version():
    """This plugin's version string from .claude-plugin/plugin.json, or None on any error (dev
    checkouts, malformed file). Stamped into the lead marker so `relay list` can name the version a
    lead armed under — the key fact when a stale pre-fix session keeps missing wakes."""
    try:
        return json.loads((_plugin_root() / ".claude-plugin" / "plugin.json").read_text()).get("version")
    except Exception:
        return None


def _version_tuple(v):
    """"0.3.14" → (0, 3, 14) for real ordering, or None if unparseable. Naive string comparison
    is a trap here — "0.3.14" < "0.3.9" lexically — and a wrong verdict either way makes the
    stale-hooks footnote lie, so unparseable versions opt out of the check entirely."""
    try:
        return tuple(int(p) for p in str(v).strip().split("."))
    except Exception:
        return None


def stop_hook_timeout():
    """The Stop hook's `timeout` (seconds) declared in THIS plugin version's hooks.json, or None if
    absent/unparseable. None is the 0.1.0 signature — no timeout field, so the harness kills the
    async wake poller at its short default and every late executor report is missed. Stamped at arm
    time so the staleness check (wake_hook_state) needs no later file lookup."""
    try:
        d = json.loads((_plugin_root() / "hooks" / "hooks.json").read_text())
        return d["hooks"]["Stop"][0]["hooks"][0].get("timeout")
    except Exception:
        return None


def append_ledger(event, **fields):
    STATE_ROOT.mkdir(parents=True, exist_ok=True)
    rec = {"ts": now(), "event": event, **fields}
    with open(LEDGER, "a") as f:
        f.write(json.dumps(rec) + "\n")


def session_dir(session_id):
    return STATE_ROOT / session_id


def packets_dir(session_id):
    return session_dir(session_id) / "packets"


def pid_path(session_id):
    return session_dir(session_id) / "pid"


def iterm_id_path(session_id):
    return session_dir(session_id) / "iterm_id"


def read_iterm_id_at(path, timeout=5):
    """Poll for a backend session id ($ITERM_SESSION_ID) written to `path` by a spawned shell before
    exec'ing claude. Returns None if it never appears (empty var / capture failed). Shared polling
    primitive for both executor spawns (via read_iterm_id below, keyed by session dir) and lead
    restores (keyed by the lead's own dir) — one poll loop, not duplicated per caller."""
    deadline = time.time() + timeout
    while time.time() < deadline:
        if path.exists():
            v = path.read_text().strip()
            if v:
                return v
        time.sleep(0.2)
    return None


def read_iterm_id(session_id, timeout=5):
    """Poll for the executor's own iTerm session id, keyed by its session dir's iterm_id file."""
    return read_iterm_id_at(iterm_id_path(session_id), timeout)


def read_session(session_id):
    p = session_dir(session_id) / "session.json"
    if not p.exists():
        return None
    return json.loads(p.read_text())


def write_session(session_id, data):
    d = session_dir(session_id)
    d.mkdir(parents=True, exist_ok=True)
    (d / "session.json").write_text(json.dumps(data, indent=2))


def all_session_ids():
    if not STATE_ROOT.exists():
        return []
    return sorted(d.name for d in STATE_ROOT.iterdir() if (d / "session.json").exists())


def next_packet_number(session_id):
    d = packets_dir(session_id)
    if not d.exists():
        return 1
    existing = sorted(p.stem.split("-")[0] for p in d.glob("*-packet.md"))
    return int(existing[-1]) + 1 if existing else 1


def build_packet(body, report_path, diff_cmd, diff_url):
    return body.rstrip() + TEMPLATE_FOOTER.format(report_path=report_path, diff_cmd=diff_cmd, diff_url=diff_url)


def packet_summary(body, limit=160):
    """A ONE-LINE gist of a packet — its first meaningful line, markdown heading markers stripped
    and whitespace collapsed — so the executor's first message shows WHAT the task is, not just a
    file path. Returns "" if nothing usable (caller then omits the summary)."""
    for raw in body.splitlines():
        line = " ".join(raw.strip().lstrip("#").strip().split())  # de-heading + collapse whitespace
        if line:
            return line[: limit - 1] + "…" if len(line) > limit else line
    return ""


def build_pointer_message(packet_path, summary=None):
    """A SHORT, single-line instruction pointing the executor at its packet file, rather than
    embedding the full (often multi-page) packet text directly into a typed/`write text`
    command. Typing a large multi-line block into an interactive shell or a running claude
    session is fragile: a fresh shell interprets embedded newlines as real Enter presses
    (visible as zsh's "quote> " continuation prompt while a multi-line quoted argument is still
    being "typed" -- confirmed empirically), and typing multi-line text into an ALREADY-RUNNING
    claude session risks the first embedded newline submitting an incomplete turn. A short
    single-line pointer sidesteps both risks for spawn and send alike. `summary` (kept single-line
    by packet_summary) is prepended so the executor's first line states the ask up front."""
    gist = f"Task — {summary}. " if summary else ""
    return (f"{gist}Read and follow the work packet at {packet_path} — it contains your task, "
            f"GATES, and REPORT FORMAT.")


def read_pid(session_id, timeout=5):
    """Poll for the pidfile spawn() asked the shell to write via `echo $$`. Returns None if it
    never appears (e.g. `claude` isn't on PATH, or the shell command failed)."""
    p = pid_path(session_id)
    deadline = time.time() + timeout
    while time.time() < deadline:
        if p.exists():
            try:
                return int(p.read_text().strip())
            except ValueError:
                pass
        time.sleep(0.2)
    return None


def auto_trust(worktree):
    """Pre-accept Claude Code's one-time workspace-trust dialog for `worktree`, so `relay spawn`
    into a brand-new directory doesn't block on a human click. This writes the exact same field
    (`hasTrustDialogAccepted`) that Claude Code itself sets when a human clicks "trust" by hand
    (confirmed by inspecting ~/.claude.json's existing entries) -- read-merge-write, touching
    only this one project's entry, never the rest of the file. Best-effort: any failure here
    (missing file, unexpected schema, concurrent write) is swallowed -- worst case the user sees
    the one-time dialog, same as without this function."""
    config_path = Path.home() / ".claude.json"
    worktree_abs = str(Path(worktree).resolve())
    try:
        config = json.loads(config_path.read_text())
        projects = config.setdefault("projects", {})
        entry = projects.setdefault(worktree_abs, {})
        if entry.get("hasTrustDialogAccepted") is True:
            return  # already trusted — don't rewrite the file at all
        entry["hasTrustDialogAccepted"] = True
        # Claude Code itself rewrites ~/.claude.json frequently (settings, project history, auth
        # state), so this must be atomic: write a sibling temp file and os.replace it, never a
        # partial in-place write. The read happens immediately above, keeping the lost-update
        # window as small as a whole-file merge allows.
        tmp = config_path.parent / (config_path.name + ".relay-tmp")
        tmp.write_text(json.dumps(config, indent=2))
        os.replace(tmp, config_path)
    except (OSError, json.JSONDecodeError):
        pass


def pid_alive(pid):
    if pid is None:
        return False
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True  # exists, just owned by someone else (won't happen for our own child)
    return True


def pid_start_time(pid):
    """Thin delegate — the single source of truth is lead_guard._pid_start_time (shared with the
    poll-lock heartbeat's pid-reuse guard, see acquire_poll_lock)."""
    return lead_guard._pid_start_time(pid)


def session_pid_alive(s):
    """pid_alive plus the pid-reuse check: alive AND (when a start time was recorded at spawn)
    still the same process. A mismatch means the pid was recycled → treat as dead."""
    pid = s.get("pid")
    if not pid_alive(pid):
        return False
    recorded = s.get("pid_started")
    if recorded:
        cur = pid_start_time(pid)
        if cur and cur != recorded:
            return False
    return True


def _transcript_project_dirs():
    """Every <config-dir>/projects/<cwd-slug> dir, or None if the projects root itself doesn't
    exist / is unreadable — the "can't tell" case conversation_transcript_exists's callers must
    not mistake for "no transcript". Shared scan behind both that function and _find_transcript_path
    (a session's transcript lives under a cwd-derived slug, so callers scan every dir rather than
    reconstructing the one slug — a session can legitimately have been opened from a path that no
    longer resolves the same way)."""
    root = Path(os.environ.get("CLAUDE_CONFIG_DIR") or (Path.home() / ".claude")) / "projects"
    try:
        return [d for d in root.iterdir() if d.is_dir()]
    except OSError:
        return None


def conversation_transcript_exists(claude_session):
    """Whether Claude Code has a transcript on disk for `claude_session` — i.e. whether that
    conversation was ever actually created. Transcripts live at
    <config-dir>/projects/<cwd-slug>/<session-uuid>.jsonl.

    Returns True, False, or None for "can't tell" — no projects root, or an unreadable one. Callers
    must treat None and False differently: a pinned id with no transcript is the §12 #21 signature
    (the launch died before Claude Code ever registered the id), but transcripts are also pruned on
    a retention schedule, so this is evidence for a WARNING, never grounds to refuse a resume on its
    own. The authority on "did this launch actually work" is _launch_survived."""
    project_dirs = _transcript_project_dirs()
    if not project_dirs:
        return None
    return any((d / f"{claude_session}.jsonl").exists() for d in project_dirs)


def _launch_survived(pid, grace=None, sleep_fn=time.sleep, clock_fn=time.time, interval=0.25):
    """Did a just-(re)launched claude still exist a grace window later? See LAUNCH_GRACE_SECONDS
    for why a freshly-read pid proves nothing on its own. A None pid (the pidfile never appeared)
    is a failed launch by definition. Polls rather than sleeping flat so the failure case — the one
    a human is waiting on a wrong success message for — returns immediately; only a genuinely
    healthy launch waits out the full window."""
    if pid is None:
        return False
    deadline = clock_fn() + (LAUNCH_GRACE_SECONDS if grace is None else grace)
    while True:
        if not pid_alive(pid):
            return False
        if clock_fn() >= deadline:
            return True
        sleep_fn(interval)


def _mark_launch_failed(session_id, s):
    """Rewrite a session's marker to say the launch didn't happen, and ledger it. Sticky: _check_one
    leaves LAUNCH_FAILED alone, so the row keeps saying so in `relay list` until a `relay restart`
    (or resume) actually relaunches it."""
    s["status"] = LAUNCH_FAILED
    s["updated"] = now()
    write_session(session_id, s)
    append_ledger("launch_failed", session_id=session_id)


def _ensure_tab_label(bk, handle, label, attempts=3, delay=1.5):
    """Verify the tab label actually took, retrying the rename if not. iTerm's spawn types
    `/rename` after a FIXED startup delay; a slow claude start (cold cache, heavy MCP init) can
    swallow it, and an unlabeled tab silently breaks everything title-based (send/close/focus,
    stalled-vs-dead). The retry goes through rename_by_id — matched by the captured handle (iTerm
    session id / Terminal window id), so it can't hit the wrong tab. Best-effort: without a
    captured handle there's nothing safe to do.

    This synchronous pass (attempts=3, delay=1.5 ≈ 4.5s) only covers the FIRST few seconds after
    launch — Claude Code sets its own OSC tab title once, ~6-8s in, derived from the task prompt,
    and silently clobbers whatever relay wrote here with nobody re-asserting afterward (confirmed
    empirically; see the relay-exec-label packet's Findings). So every return path here also kicks
    off `_launch_background_label_assert`, a detached follow-up that re-renames PAST that ~6-8s
    clobber point — durably, but without making spawn/relaunch block for it."""
    if not handle:
        return False
    for _ in range(attempts):
        if bk.is_alive(label, handle):
            _launch_background_label_assert(bk, handle, label)
            return True
        bk.rename_by_id(handle, label)
        time.sleep(delay)
    ok = bk.is_alive(label, handle)
    _launch_background_label_assert(bk, handle, label)
    return ok


def _launch_background_label_assert(bk, handle, label):
    """Detached follow-up to _ensure_tab_label's synchronous attempts, launched as its very last
    step: spawns `relay _ensure-label <handle> <label>` as a fully independent subprocess
    (start_new_session=True so it survives this relay invocation exiting) that polls PAST Claude
    Code's one-time ~6-8s OSC titling and re-renames until the label sticks — see
    _background_label_loop. NEVER blocks the caller (cmd_spawn/_relaunch) on it: Popen returns
    immediately, and any failure to even launch is swallowed, exactly like a labeling failure must
    never break or delay the spawn itself.

    iTerm-only (`bk.NAME == "iterm"`): Terminal.app sets its custom tab title once via
    rename_by_id at spawn time and nothing ever re-titles it afterward (no Claude OSC clobber to
    outlast there), so there's nothing for a background pass to fix — today's behavior is kept
    unchanged."""
    if getattr(bk, "NAME", None) != "iterm" or not handle:
        return
    try:
        subprocess.Popen(
            [sys.executable, RELAY_BIN, "_ensure-label", handle, label],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, stdin=subprocess.DEVNULL,
            start_new_session=True,
        )
    except Exception:
        pass


def _label_holds_for_tab(handle, label):
    """Does THIS tab currently carry `label`? The identity-aware title check (backlog §2).

    With a handle, ask that one session what its title is (iterm.title_by_id) and bounded-match it.
    The question the old code asked — `title_is_live(label, live_session_names())`, i.e. "does ANY
    live tab carry this label" — is only equivalent while labels are unique, and relay's aren't: a
    handoff gives predecessor and successor the SAME `[Lead] <project>` title and writes the
    successor's marker before stepping the predecessor down, so during that window the successor
    reads the predecessor's correctly-titled tab as proof of its own and never titles itself.
    Reproduced at the seam (see the packet's repro), which upgrades §2 from hypothesis to bug.

    A None from title_by_id means the tab couldn't be read at all (closed, or the probe failed) and
    is deliberately NOT treated as "the label holds" — an unreadable tab is not a titled tab. It
    returns False, so the caller re-asserts; a rename against a gone session is a harmless no-op,
    whereas believing a vanished tab is correctly titled is the §2 bug again.

    Without a handle (legacy/pre-capture sessions) there is no identity to ask about, so it falls
    back to the old any-tab scan — imprecise, but strictly better than refusing to check at all."""
    if handle:
        title = iterm_backend.title_by_id(handle)
        return bool(title) and iterm_backend.title_is_live(label, {title})
    return iterm_backend.title_is_live(label, iterm_backend.live_session_names())


def _background_label_loop(handle, label, window=27.0, interval=3.0, hold_checks=2,
                            sleep_fn=time.sleep, clock_fn=time.time):
    """The durable half of the [Exec]-label fix: runs INSIDE the detached subprocess launched by
    _launch_background_label_assert. Polls THIS tab's actual title (_label_holds_for_tab, keyed by
    the captured handle — a real title read, not is_alive's id short-circuit, which would report
    the tab "alive" without checking what its title currently says) and re-renames via
    rename_by_id whenever it isn't (still) `label`, over a bounded window (~25-30s by default — a
    few seconds past Claude Code's observed ~6-8s one-time titling).

    Requires `hold_checks` (default 2) CONSECUTIVE live reads of `label` before declaring success
    and exiting early, not just one: the very first post-clobber read could itself land moments
    before Claude's titling actually fires. Since Claude only ever titles once, two clean reads in
    a row means no further clobber is coming, so the loop doesn't need to burn its whole window.
    Returns True if the label was confirmed to hold (by the hold-checks streak, whether that
    happened immediately or after re-renames), False if the window ran out first."""
    consecutive = 0
    deadline = clock_fn() + window
    while clock_fn() < deadline:
        if _label_holds_for_tab(handle, label):
            consecutive += 1
            if consecutive >= hold_checks:
                return True
        else:
            consecutive = 0
            iterm_backend.rename_by_id(handle, label)
        sleep_fn(interval)
    return consecutive >= hold_checks


def cmd_ensure_label(args):
    """Hidden subcommand: the entry point for the detached background process
    _launch_background_label_assert spawns (`relay _ensure-label <handle> <label>`). Not meant to
    be typed by a human. Never raises — a labeling failure in a background process with nobody
    watching its exit code must not surface anywhere."""
    try:
        _background_label_loop(args.handle, args.label)
    except Exception:
        pass


def _kill_and_wait(s, timeout=3.0):
    """SIGTERM the session's process and WAIT until it is actually gone (escalating to SIGKILL at
    the deadline). A fixed post-kill sleep raced the terminal's 'process still running' confirm
    sheet — once that sheet is up, Terminal.app silently ignores every scripted close of the window
    (observed live), so the tab could never be cleaned up again."""
    if not session_pid_alive(s):
        return
    pid = s["pid"]
    try:
        os.kill(pid, signal.SIGTERM)
    except Exception:
        return
    deadline = time.time() + timeout
    while time.time() < deadline:
        if not pid_alive(pid):
            return
        time.sleep(0.1)
    try:
        os.kill(pid, signal.SIGKILL)
        time.sleep(0.2)
    except Exception:
        pass


def cmd_spawn(args):
    body = Path(args.packet).read_text()
    session_id = args.name or f"{slugify(args.topic)}-{time.strftime('%H%M%S')}"
    if read_session(session_id):
        sys.exit(f"session '{session_id}' already exists — pick a different --name or use `relay send`")

    # Resolve the worktree to an ABSOLUTE, existing dir. The spawned tab opens in iTerm's default cwd
    # (not the lead's), so the `cd <worktree>` in the launch command must be absolute — a relative or
    # bogus path (e.g. the lead accidentally passing a session-name-like string) would `cd` into
    # nothing, the `&&` chain would die, and `exec claude` would never run (silently broken tab).
    # Fail loudly here instead.
    worktree = str(Path(args.worktree).expanduser().resolve())
    if not Path(worktree).is_dir():
        sys.exit(f"spawn: worktree not found — '{args.worktree}' resolved to '{worktree}', which is "
                 f"not a directory. Pass the existing project directory all executors share "
                 f"(an absolute path, e.g. /tmp/calc).")

    # Resolve the model BEFORE any packet/session files are written: an explicit --model always
    # wins; otherwise relay's own executor_default_model policy applies — never the CLI's personal
    # `/model` default (see the "executor model policy" section in lead_guard.py). A requested model above
    # executor_model_ceiling is refused unless --model-override "<reason>" is given, so a lead can't
    # accidentally (or silently) spawn an executor on the top-tier model without a deliberate,
    # ledgered reason.
    cfg = lead_guard.load_config(STATE_ROOT)
    resolved_model = args.model or cfg.get("executor_default_model", "sonnet")
    ceiling = cfg.get("executor_model_ceiling", "opus")
    if lead_guard.model_exceeds_ceiling(resolved_model, ceiling):
        if not args.model_override:
            sys.exit(f"spawn: requested model '{resolved_model}' is above the configured ceiling "
                     f"'{ceiling}' — pass --model-override \"<reason>\" to spawn on it anyway.")
        append_ledger("model_ceiling_override", session_id=session_id, model=resolved_model,
                      reason=args.model_override)

    auto_trust(worktree)
    label = f"[Exec] {session_id}"  # role-prefixed: exec tabs and lead tabs are told apart at a glance
    d = packets_dir(session_id)
    d.mkdir(parents=True, exist_ok=True)
    n = 1
    report_path = str(d / f"{n:03d}-report.md")
    diff_cmd = f"{RELAY_BIN} diff {session_id}"
    diff_path = d / f"{n:03d}-diff.html"
    diff_url = path_to_file_url(diff_path)
    packet_path = d / f"{n:03d}-packet.md"
    packet_path.write_text(build_packet(body, report_path, diff_cmd, diff_url))

    # Whether the executor runs with --dangerously-skip-permissions. Per-spawn flag wins; else the
    # config default (executor_skip_permissions, default False = safe/prompts). Skip-perms means the
    # executor edits files / runs commands without prompting — mitigated by relay's design
    # (executors STAGE, never commit; the lead reviews before anything lands), but a real tradeoff.
    skip_perms = args.skip_perms if args.skip_perms is not None else bool(cfg.get("executor_skip_permissions", False))
    # Same tri-state pattern as skip_perms: --pane/--tab wins; else config's executor_layout
    # ("tab" default). "pane" only takes effect if the lead's iTerm session can be located at
    # spawn time (see iterm.spawn's lead_handle/layout docstring) — otherwise it degrades to a tab.
    if args.pane is not None:
        layout = "pane" if args.pane else "tab"
    else:
        layout = cfg.get("executor_layout", "tab")
    # Pin the executor's Claude Code session id so `relay resume` can reopen this exact conversation
    # later (via `claude --resume <uuid>`) without scraping transcripts.
    claude_session = str(uuid.uuid4())

    # Stamp this executor with the lead that spawned it. --lead wins; else the calling lead's own
    # session id from the env; else unowned (None). The human-readable project AND the lead's tab
    # color come from the owning lead's marker — executors inherit the color so a lead's tabs group
    # visually (iTerm only; Terminal ignores it).
    owner_lead = getattr(args, "lead", None) or os.environ.get("CLAUDE_CODE_SESSION_ID") or None
    owner_marker = lead_guard.read_marker(STATE_ROOT, owner_lead) if owner_lead else {}
    owner_project = owner_marker.get("project")
    tab_color = owner_marker.get("color") if cfg.get("tab_colors", True) else None

    # Arm the executor-side wake escalation (wake-watch design §4): a plain `claude` launch gets NO
    # hooks, so this executor only gets the escalation Stop hook if we pass it explicitly here.
    settings_file = _maybe_escalation_settings_file(session_id)

    def launch_attempt():
        """One full launch: open the tab, then read back the two INDEPENDENT signals that say it
        actually happened — the pidfile the spawned shell writes, and whether the tab label took.
        Clears both capture files first so a retry can't read the previous attempt's leftovers."""
        for f in (pid_path(session_id), iterm_id_path(session_id)):
            try:
                f.unlink()
            except FileNotFoundError:
                pass
        iterm.spawn(
            cwd=worktree,
            prompt=build_pointer_message(str(packet_path), packet_summary(body)),
            label=label,
            pidfile=str(pid_path(session_id)),
            model=resolved_model,
            skip_perms=skip_perms,
            iterm_id_file=str(iterm_id_path(session_id)),
            session_uuid=claude_session,
            tab_color=tab_color,
            settings_file=settings_file,
            lead_handle=owner_marker.get("iterm_session"),
            layout=layout,
        )
        pid = read_pid(session_id)
        handle = read_iterm_id(session_id)  # backend handle (iTerm session id / Terminal "twid:N")
        return pid, handle, _ensure_tab_label(iterm, handle, label)

    pid, iterm_session, label_ok = launch_attempt()
    # BOTH signals missing means nothing came back from the launch at all — the observed signature
    # of the §12 launch race (a human typing into iTerm during the AppleScript tab setup). Either
    # signal alone is just a degraded-but-live tab, so only the both-failed case retries here.
    if pid is None and not label_ok:
        print(f"spawn: no PID and the tab title '{label}' didn't take — the launch may not have "
              f"happened at all; retrying it once…", file=sys.stderr)
        pid, iterm_session, label_ok = launch_attempt()
    launch_failed = pid is None and not label_ok

    write_session(session_id, {
        "session_id": session_id,
        "owner_lead": owner_lead,
        "owner_project": owner_project,
        "worktree": worktree,
        "topic": args.topic,
        "scope": args.scope or args.topic,
        "tab_label": label,
        "model": resolved_model,  # the resolved effective model, even when --model was omitted —
                                  # never store null just because the caller didn't pass one (that's
                                  # what let `relay list` render `-` for a live executor)
        "pid": pid,
        "pid_started": pid_start_time(pid) if pid else None,  # pid-reuse guard (see session_pid_alive)
        "iterm_session": iterm_session,
        "backend": iterm.NAME,  # which terminal app owns this tab — ops keep addressing it there
        "claude_session": claude_session,
        # Never `busy` for a launch nothing came back from — see LAUNCH_FAILED.
        "status": LAUNCH_FAILED if launch_failed else "busy",
        "current_packet": n,
        "busy_since": now(),
        "busy_since_epoch": time.time(),  # DST-proof elapsed math; the ISO string stays for humans
        "superseded_by": None,
        "created": now(),
        "updated": now(),
    })
    append_ledger("spawned", session_id=session_id, worktree=worktree, topic=args.topic, tab_label=label)
    append_ledger("packet_sent", session_id=session_id, packet=n)
    if launch_failed:
        append_ledger("launch_failed", session_id=session_id, attempts=2)
        print(f"spawn: claude did NOT launch for '{session_id}' — no PID and the tab title "
              f"'{label}' never took, on the first attempt AND the retry. The session is recorded "
              f"{LAUNCH_FAILED} (not busy): nothing is working on packet {n:03d}, and its pinned "
              f"conversation id was never registered, so `relay resume` cannot help.\n"
              f"  Recover with: relay restart {session_id}   "
              f"(fresh tab, fresh conversation id, same packet)", file=sys.stderr)
        sys.exit(1)  # message already printed; a spawn that launched nothing must not exit 0
    if pid is None:
        print(f"spawned session '{session_id}' (tab '{label}') with packet {n:03d} — WARNING: could not read PID, aliveness/stall detection will rely on tab title only")
    else:
        print(f"spawned session '{session_id}' (tab '{label}', pid {pid}) with packet {n:03d}")
    if not label_ok:
        print(f"WARNING: tab title '{label}' didn't take — send/close/focus may not find this tab "
              f"(retry with: relay focus {session_id})", file=sys.stderr)


def _relaunch(session_id, s, prompt, resume_id=None, session_uuid=None):
    """(Re)launch claude in a fresh tab for an existing session record and refresh its live state.
    Shared by restart (fresh session_uuid, re-run packet) and resume (--resume the old conversation).
    Clears the stale pid/iterm-id files first so read_pid/read_iterm_id wait for the NEW tab's."""
    auto_trust(s["worktree"])
    bk = term_backend(s)
    label = s.get("tab_label") or f"[Exec] {session_id}"
    for p in (pid_path(session_id), iterm_id_path(session_id)):
        try:
            p.unlink()
        except FileNotFoundError:
            pass
    cfg = lead_guard.load_config(STATE_ROOT)
    skip_perms = bool(cfg.get("executor_skip_permissions", False))
    # Re-inherit the owning lead's tab color (the fresh tab starts uncolored).
    tab_color = None
    if cfg.get("tab_colors", True) and s.get("owner_lead"):
        tab_color = lead_guard.read_marker(STATE_ROOT, s["owner_lead"]).get("color")
    # A resume (`resume_id` set) reopens the SAME conversation — build_claude_cmd doesn't even pass
    # --model on that path, so whatever model that conversation already runs is exempt and untouched
    # here. A restart (`session_uuid` set) is a genuinely FRESH launch though, so it gets the same
    # relay-owned default-model policy as a first spawn — a legacy/null s["model"] must not silently
    # fall through to the CLI's personal default a second time.
    model = s.get("model")
    if session_uuid and not model:
        model = cfg.get("executor_default_model", "sonnet")
        s["model"] = model
    bk.spawn(
        cwd=s["worktree"],
        prompt=prompt,
        label=label,
        pidfile=str(pid_path(session_id)),
        model=model,
        skip_perms=skip_perms,
        iterm_id_file=str(iterm_id_path(session_id)),
        session_uuid=session_uuid,
        resume_id=resume_id,
        tab_color=tab_color,
        settings_file=_maybe_escalation_settings_file(session_id),  # re-arm escalation on the fresh tab too —
                                                          # a resumed/restarted executor must not
                                                          # silently lose wake coverage
    )
    pid = read_pid(session_id)
    s["pid"] = pid
    s["pid_started"] = pid_start_time(pid) if pid else None
    s["iterm_session"] = read_iterm_id(session_id)
    _ensure_tab_label(bk, s["iterm_session"], label)
    if session_uuid:  # restart minted a fresh conversation; resume keeps the existing claude_session
        s["claude_session"] = session_uuid
    s["status"] = "busy"
    s["busy_since"] = now()
    s["busy_since_epoch"] = time.time()
    s["updated"] = now()
    write_session(session_id, s)
    return pid, label


def _lead_alive(lead_sid):
    """Whether `lead_sid` still plausibly has a live session behind it — the gate for whether an
    executor's ownership can be re-parented freely (dead/retired owner) or must warn instead (live
    owner). Deliberately does NOT match on tab_label: a handoff (old lead + new lead, SAME project)
    gives both the identical relay-controlled label, so label matching would read the dead lead's
    recorded label as a match for the new lead's own live tab and block the exact handoff transfer
    this exists for. pid and iterm_session are per-process/per-tab identities that can't collide
    across a handoff. Any exception (or an unresolvable identity) fails toward False — a
    wrongly-alive verdict silently re-kills the wake (the bug this fixes); a wrongly-dead verdict
    just transfers ownership, which the printed adoption line makes visible."""
    try:
        marker = lead_guard.read_marker(STATE_ROOT, lead_sid)
        if not marker:
            return False
        pid_file = lead_guard.lead_dir(STATE_ROOT, lead_sid) / "pid"
        if pid_file.exists() and pid_alive(int(pid_file.read_text().strip())):
            return True
        iterm_session = marker.get("iterm_session")
        if iterm_session and iterm.tty_by_id(iterm_session):
            return True
        return False
    except Exception:
        return False


def _maybe_adopt(session_id, s, force=False, quiet=False):
    """Re-parent an executor's ownership to the acting lead at a claim point (send/resume/restart/
    adopt) — sending or resuming a session is an unambiguous claim of it, so ownership should
    follow. Fixes the silent handoff bug where `owner_lead` is stamped once at spawn and never
    updated, permanently disabling auto-wake for every lead that inherits an executor after a
    handoff. Returns `s` (mutated + already persisted if ownership changed)."""
    caller = os.environ.get("CLAUDE_CODE_SESSION_ID")
    if not caller or not lead_guard.is_lead(STATE_ROOT, caller) or s.get("owner_lead") == caller:
        return s
    owner = s.get("owner_lead")
    if owner is None or not _lead_alive(owner) or force:
        caller_marker = lead_guard.read_marker(STATE_ROOT, caller)
        s["owner_lead"] = caller
        s["owner_project"] = caller_marker.get("project")
        s["updated"] = now()
        write_session(session_id, s)
        append_ledger("adopted", session_id=session_id, from_lead=owner, to_lead=caller, forced=bool(force))
        if not quiet:
            if owner:
                print(f"adopted '{session_id}' from retired lead {owner[:8]}…")
            else:
                print(f"adopted unowned '{session_id}'")
        return s
    if not quiet:
        print(f"WARNING: '{session_id}' is owned by live lead {owner[:8]}… ({s.get('owner_project')}) "
              f"— its report will wake THEM, not you. Take it with: relay adopt {session_id} --force",
              file=sys.stderr)
    return s


def cmd_restart(args):
    """Re-run a session's CURRENT packet in a fresh tab as a NEW conversation. Loses the prior
    conversation context and re-does the packet from scratch — use `relay resume` to keep context.
    For a session whose tab was closed or whose process died."""
    sid = args.session_id
    s = read_session(sid)
    if not s:
        sys.exit(f"no such session: {sid}")
    if session_pid_alive(s) and not args.force:
        sys.exit(f"session '{sid}' still looks alive (pid {s.get('pid')}) — close it first or pass --force")
    n = s.get("current_packet", 1)
    packet_path = packets_dir(sid) / f"{n:03d}-packet.md"
    if not packet_path.exists():
        sys.exit(f"cannot restart '{sid}': packet {n:03d} not found at {packet_path}")
    pointer = build_pointer_message(str(packet_path), packet_summary(packet_path.read_text()))
    s = _maybe_adopt(sid, s)
    pid, label = _relaunch(sid, s, pointer, session_uuid=str(uuid.uuid4()))
    append_ledger("restarted", session_id=sid, packet=n)
    print(f"restarted '{sid}' (tab '{label}', pid {pid}) — re-running packet {n:03d} as a fresh session")


def cmd_resume_lead(sid, force=False):
    """Restore a crashed LEAD by reopening its OWN Claude Code conversation via `claude --resume
    <sid>` (a lead's session_id IS its Claude session id). The marker survived the crash on disk;
    the nudge tells the restored lead to re-run `relay lead-start` under its CURRENT session id —
    idempotent if `--resume` kept the id, and the re-arm path if it minted a fresh one (in which
    case the hooks would otherwise silently miss the old marker and lead mode would be inactive
    while looking armed). Reopens in the marker's cwd and refreshes `last_active` so the restored
    lead looks fresh in `relay list`. Leads live only under lead/<sid>/ — this writes NO executor
    session.json and uses the lead's own dir for the pidfile."""
    marker = lead_guard.read_marker(STATE_ROOT, sid)
    project = marker.get("project")
    cwd = marker.get("cwd") or os.getcwd()
    model = marker.get("model")
    # Same label scheme as lead-start — the marker's tab_label must match the actual tab title or
    # `relay focus <lead>` breaks after a restore.
    label = f"[Lead] {slugify(project)}" if project else f"[Lead] {sid}"
    # Refuse to open a SECOND live copy of the same conversation (mirrors the executor guard).
    # Aliveness: a pid recorded by a previous restore, else the marker's relay-controlled tab title.
    lead_pid_file = lead_guard.lead_dir(STATE_ROOT, sid) / "pid"
    alive = False
    try:
        alive = pid_alive(int(lead_pid_file.read_text().strip()))
    except Exception:
        alive = False
    if not alive and marker.get("tab_label"):
        # Ask about THIS lead's tab, not "is some tab called that" — the marker's own backend and
        # handle, via _lead_tab_target. Label-only (what this used to be) reads a handoff sibling's
        # identically-titled tab as proof this lead is alive and refuses a restore it should have
        # allowed (backlog §2, same shape as the label-loop bug).
        lead_bk, lead_label, lead_handle = _lead_tab_target(marker)
        alive = lead_bk.is_alive(lead_label, lead_handle)
    if alive and not force:
        sys.exit(f"lead '{sid}' still looks alive — close its tab first or pass --force "
                 f"(two live copies of one conversation stomp on each other)")
    relay_bin = str(Path(__file__).resolve())
    proj_flag = f" --project {shlex.quote(project)}" if project else ""
    nudge = (f"You are the resumed lead for project '{project}'. FIRST verify arming: run "
             f"`{relay_bin} lead-start \"$CLAUDE_CODE_SESSION_ID\"{proj_flag}` — idempotent if your "
             f"session id survived the resume, and it re-arms lead mode under your new id if "
             f"`--resume` minted a fresh one. If your current session id differs from '{sid}', also "
             f"run `{relay_bin} close --self {sid}` to clear the stale marker. Then run /relay:list "
             "to reconstruct what's in flight and continue where you left off.")
    cfg = lead_guard.load_config(STATE_ROOT)
    skip_perms = bool(cfg.get("executor_skip_permissions", False))
    color = marker.get("color") if cfg.get("tab_colors", True) else None
    lead_pid = lead_guard.lead_dir(STATE_ROOT, sid) / "pid"
    # Capture the fresh tab's backend session id the same way executor spawns do (read_iterm_id_at),
    # so a restored lead keeps its iTerm identity: adjacent-tab placement for its executors, tier-1
    # tty desktop notifications, and _lead_alive's tty probe all key off marker.iterm_session — leaving
    # it None silently and permanently degrades all three until the lead happens to re-arm in-tab.
    iterm_id_file = lead_guard.lead_dir(STATE_ROOT, sid) / "iterm_id"
    try:
        iterm_id_file.unlink()  # drop any stale value from a prior restore before spawning the new tab
    except FileNotFoundError:
        pass
    iterm.spawn(
        cwd=cwd,
        prompt=nudge,
        label=label,
        pidfile=str(lead_pid),
        model=model,
        skip_perms=skip_perms,
        resume_id=sid,
        tab_color=color,  # the restored tab keeps the lead's color (fresh tabs start unpainted)
        iterm_id_file=str(iterm_id_file),
    )
    iterm_session = read_iterm_id_at(iterm_id_file)  # best-effort; None on timeout doesn't block the restore
    # Refresh the marker (same project/cwd/model, PLUS tab_label and color — dropping them here
    # used to break `relay focus <lead>` after a restore) so last_active updates and the restored
    # lead looks fresh in `relay list`. iterm_session is captured above; None only on a capture
    # timeout, in which case behavior degrades to exactly what it was before this fix.
    #
    # write_marker writes the WHOLE marker, so every field this call omits is silently DROPPED from
    # a lead that had it — the §1 disease. Each one below is therefore deliberate:
    #   backend      — re-stamped, not preserved: `iterm.spawn` above just created this lead's new
    #                  tab, so the backend hosting it is THIS invocation's, whatever the crashed
    #                  instance ran under. That also settles §1's open "should a revive re-stamp
    #                  backend" question for this path — we're not guessing, we opened the tab.
    #   started      — PRESERVED: it means "when this lead began", and a restore is the same lead.
    #   predecessor  — PRESERVED: it's the only record of the handoff-zombie tab `relay
    #                  close-predecessor` closes, and dropping it stranded that tab permanently.
    #   autonomous   — RESET to the safe wait-for-human posture, never preserved (§6f: it is
    #                  opt-in-each-time and resets on arm; see write_marker's own docstring). Left
    #                  at False rather than read from `autonomous_mode` config on purpose:
    #                  cmd_lead_start is the one site that applies that config, and it ANNOUNCES an
    #                  auto arm in its output. Stamping auto from here would arm a lead into the
    #                  inverted posture with nothing said — the silent autonomy §6f warns against.
    #                  The restore nudge tells the lead to re-run `relay lead-start`, which applies
    #                  the config default and announces it, so nothing is lost by waiting for that.
    lead_guard.write_marker(STATE_ROOT, sid, model=model, project=project, cwd=cwd,
                            tab_label=label, color=color, iterm_session=iterm_session,
                            plugin_version=plugin_version(), stop_hook_timeout=stop_hook_timeout(),
                            backend=iterm.NAME,
                            started=marker.get("started"),
                            predecessor=marker.get("predecessor"),
                            autonomous=False, autonomous_source="config")
    append_ledger("lead_resumed", session_id=sid, project=project)
    print(f"restored lead '{project}' (session {sid}) — reopening its conversation")


def cmd_resume(args):
    """Reopen a session's EXISTING conversation in a fresh tab via `claude --resume` — full context
    and the worktree's staged work intact. Routes lead-vs-executor: an executor resumes its captured
    Claude session id; a crashed LEAD (marker present, no session.json) restores its own conversation
    via cmd_resume_lead. For a session whose tab closed / died."""
    sid = args.session_id
    s = read_session(sid)
    if not s:
        if lead_guard.is_lead(STATE_ROOT, sid):
            return cmd_resume_lead(sid, force=args.force)
        sys.exit(f"no such session: {sid}")
    cs = s.get("claude_session")
    if not cs:
        sys.exit(f"cannot resume '{sid}': no captured Claude session id (spawned before session-id "
                 f"capture). Use `relay restart {sid}` to re-run its packet as a fresh session.")
    if session_pid_alive(s) and not args.force:
        sys.exit(f"session '{sid}' still looks alive (pid {s.get('pid')}) — close it first or pass --force")
    # A conversation id that was never created can NEVER become valid, so resuming it is an
    # infinite loop of identical failures (§12 #21). When spawn already recorded that the launch
    # never happened, that's definitive — refuse here rather than relaunch into the same wall.
    if s.get("status") == LAUNCH_FAILED and not args.force:
        sys.exit(f"cannot resume '{sid}': its launch never happened (recorded {LAUNCH_FAILED}), so "
                 f"the pinned conversation {cs} was never created — `claude --resume` would exit "
                 f"instantly, and would do so on every retry forever.\n"
                 f"  Use: relay restart {sid}   (mints a FRESH conversation id and re-runs its "
                 f"packet)\n"
                 f"  --force resumes anyway if you believe the conversation does exist.")
    # Weaker, pre-fix-era version of the same signal: no transcript on disk for the pinned id.
    # Only a warning — transcripts are also pruned on a retention schedule (see the helper).
    if conversation_transcript_exists(cs) is False:
        print(f"WARNING: no Claude Code transcript exists for '{sid}'s conversation {cs} — it may "
              f"never have been created (a launch that died before Claude Code registered the id). "
              f"If this resume dies immediately, use `relay restart {sid}` instead.", file=sys.stderr)
    nudge = ("You were resumed after your relay tab closed — your staged work in this worktree is "
             "intact. Pick up your packet where you left off, finish it, then write your report to "
             "the same report path as before.")
    s = _maybe_adopt(sid, s)
    pid, label = _relaunch(sid, s, nudge, resume_id=cs)
    append_ledger("resumed", session_id=sid, claude_session=cs)
    # _relaunch has already written a `busy` marker off the freshly-read pid. Only report success
    # once that pid has actually survived a grace window — otherwise say plainly that it died and
    # leave the marker honest, instead of printing "resumed … pid N" over a dead tab (§12 #21).
    if not _launch_survived(pid):
        _mark_launch_failed(sid, s)
        sys.exit(f"resume of '{sid}' FAILED: the relaunched claude exited immediately"
                 f"{f' (pid {pid} is already gone)' if pid else ' (no PID was ever written)'} — "
                 f"the conversation {cs} was almost certainly never created, so every retry will "
                 f"fail identically. Recorded {LAUNCH_FAILED}.\n"
                 f"  Use: relay restart {sid}   (mints a FRESH conversation id and re-runs its "
                 f"packet)")
    print(f"resumed '{sid}' (tab '{label}', pid {pid}) — reopened conversation with full context")


def cmd_send(args):
    s = read_session(args.session_id)
    if not s:
        sys.exit(f"no such session: {args.session_id}")
    # (A) Refresh REAL liveness before the guard. s["status"] is the STORED value — set to `busy`
    # at spawn and only ever recomputed when `relay check`/`list` runs _check_one. So a session
    # that has already reported still reads `busy` on disk and would be falsely refused. Recompute
    # via the same mechanism check uses (it persists the fresh status), then re-read and decide on
    # the fresh value: an idle, already-reported session becomes a valid target; a genuinely busy
    # one (process alive, no report yet) is still correctly refused below.
    _check_one(args.session_id)
    s = read_session(args.session_id)
    if s["status"] in ("busy", "stalled"):
        sys.exit(f"session '{args.session_id}' is {s['status']} — refusing to send (would inject mid-turn). Only reported/idle sessions are safe send targets.")
    if s["status"] == "superseded":
        sys.exit(f"session '{args.session_id}' is superseded by {s.get('superseded_by')} — refusing to send into an abandoned session.")
    # No tab and no valid conversation to fall back on — both delivery paths below are doomed, and
    # the resume one would loop forever on a conversation id that was never created (§12 #21).
    if s["status"] == LAUNCH_FAILED:
        sys.exit(f"session '{args.session_id}' is {LAUNCH_FAILED} — claude never launched for it, so "
                 f"there is no tab to send to and no conversation to resume. Bring it up first with: "
                 f"relay restart {args.session_id}")
    # A session whose tab is gone — `dead` (crashed / tab closed) OR `closed` (deliberately retired by
    # the lead, then wanted back for follow-up) — is still deliverable when we pinned its Claude
    # conversation at spawn: skip the doomed live-tab send and RESUME it, reopening the same
    # conversation with the new packet in one shot (full context + staged work back). Only a gone
    # session with NO captured conversation id truly needs a fresh spawn.
    prev_status = s["status"]
    tab_gone = prev_status in ("dead", "closed")
    if tab_gone and not s.get("claude_session"):
        sys.exit(f"session '{args.session_id}' is {prev_status} with no captured Claude session to "
                 f"resume — use `relay spawn` for a fresh one")

    # Claim ownership BEFORE delivery, so the poller arms for the CALLING lead the moment the
    # packet lands — whether it's delivered via the live-tab path or the resume-fallback below.
    s = _maybe_adopt(args.session_id, s)

    n = next_packet_number(args.session_id)
    body = Path(args.packet).read_text()
    report_path = str(packets_dir(args.session_id) / f"{n:03d}-report.md")
    diff_cmd = f"{RELAY_BIN} diff {args.session_id}"
    diff_path = packets_dir(args.session_id) / f"{n:03d}-diff.html"
    diff_url = path_to_file_url(diff_path)
    packet_path = packets_dir(args.session_id) / f"{n:03d}-packet.md"
    packet_path.write_text(build_packet(body, report_path, diff_cmd, diff_url))

    pointer = build_pointer_message(str(packet_path), packet_summary(body))
    ok = False if tab_gone else term_backend(s).send(s["tab_label"], pointer,
                                                     s.get("iterm_session"), s.get("pid"))
    if not ok:
        # (B) The tab is gone. If we pinned this session's Claude conversation at spawn, don't
        # force a cold spawn — RESUME the conversation and deliver the new packet in one shot via
        # the shared relaunch path. This brings the full context back AND lands the packet.
        cs = s.get("claude_session")
        if cs:
            # The old tab can still be ALIVE here (Terminal backend: send can't inject into a
            # running process, so every follow-up takes this resume path) — kill + close it FIRST,
            # or `--resume` would open a second live copy of the same conversation alongside the
            # first. Only reported/idle sessions reach this point (busy/stalled were refused above),
            # so the process is sitting at its prompt with its work staged — safe to terminate.
            _kill_and_wait(s)
            term_backend(s).close(s.get("tab_label", ""), s.get("iterm_session"), s.get("pid"))
            _relaunch(args.session_id, s, pointer, resume_id=cs)  # sets status busy, pid, writes s
            s["current_packet"] = n
            s["updated"] = now()
            write_session(args.session_id, s)
            append_ledger("packet_sent", session_id=args.session_id, packet=n, via="resume")
            note = (f"session '{args.session_id}' was {prev_status}"
                    if prev_status in ("closed", "dead")
                    else f"tab '{s['tab_label']}' was gone")
            print(f"{note} — resumed with full context and delivered packet {n:03d}")
            return
        # No captured Claude session (spawned before session-id capture) → today's behavior.
        s["status"] = "dead"
        s["updated"] = now()
        write_session(args.session_id, s)
        append_ledger("closed", session_id=args.session_id, reason="tab not found on send")
        sys.exit(f"could not find live tab '{s['tab_label']}' — marked session dead. Use `relay spawn` for a fresh one.")

    s["status"] = "busy"
    s["current_packet"] = n
    s["busy_since"] = now()
    s["busy_since_epoch"] = time.time()
    s["updated"] = now()
    write_session(args.session_id, s)
    append_ledger("packet_sent", session_id=args.session_id, packet=n)
    print(f"sent packet {n:03d} to session '{args.session_id}' (existing tab)")


def cmd_adopt(args):
    """Explicitly re-point an executor's auto-wake ownership to this lead, without sending or
    resuming it. Wraps the same _maybe_adopt logic send/resume/restart apply automatically — for
    the case where a lead just wants to claim an inherited executor up front (e.g. right after
    /relay:mode on a handoff day)."""
    s = read_session(args.session_id)
    if not s:
        sys.exit(f"no such session: {args.session_id}")
    caller = os.environ.get("CLAUDE_CODE_SESSION_ID")
    if not caller or not lead_guard.is_lead(STATE_ROOT, caller):
        sys.exit("adopt: caller isn't an armed lead — run /relay:mode first (adoption re-points "
                 "auto-wake, which only exists for leads)")
    s = _maybe_adopt(args.session_id, s, force=args.force)
    if s.get("owner_lead") != caller:
        sys.exit(1)


def _busy_elapsed(s):
    """Seconds this session has been busy, or None if unknowable. Prefers the epoch stamp (immune
    to DST shifts); falls back to parsing the ISO string for pre-epoch records. Never throws — one
    hand-edited or legacy session.json must not take down `relay list`/`check --all`."""
    try:
        e = s.get("busy_since_epoch")
        if e:
            return time.time() - float(e)
        busy_since = time.strptime(s["busy_since"], "%Y-%m-%dT%H:%M:%S")
        return time.mktime(time.localtime()) - time.mktime(busy_since)
    except Exception:
        return None


def _mark_report_surfaced(s):
    """Stamp the owning lead's surfaced_reports.json for a session's current-packet report, if one
    exists — the fix for the asymmetric dedup (backlog §5b / task #17). Before this, ONLY the lead's
    own at-Stop wake path called lg.mark_surfaced; a report reviewed through any other channel
    (`relay check`, `relay diff`, `relay close`) left the dedup unstamped, so the next at-Stop check
    still saw it as new and re-announced an already-handled report. These are all channels where the
    lead has DEMONSTRABLY handled the report (not merely been notified of it — see the explicit
    "do not mark on the mere nudge" warning in the backlog), so it's safe to stamp here. Best-effort;
    a missing owner_lead or report is simply a no-op, never an error."""
    owner_lead = s.get("owner_lead")
    n = s.get("current_packet")
    if not owner_lead or n is None:
        return
    if not (packets_dir(s["session_id"]) / f"{n:03d}-report.md").exists():
        return
    lead_guard.mark_surfaced(STATE_ROOT, owner_lead, [f"{s['session_id']}:{n}"])


def _check_one(session_id):
    s = read_session(session_id)
    if not s:
        return {"session_id": session_id, "error": "no such session"}

    # LAUNCH_FAILED is sticky like the other terminal states: it records something the aliveness
    # probes below cannot re-derive (claude never came up, so the pinned conversation id is void).
    # Letting it be recomputed would relabel it `dead`, which reads as "it ran and then died".
    if s["status"] not in ("dead", "superseded", "closed", LAUNCH_FAILED):
        n = s["current_packet"]
        report = packets_dir(session_id) / f"{n:03d}-report.md"
        proc_alive = session_pid_alive(s)
        # Liveness is PROCESS-primary (recorded pid), NOT tab-title-primary. Claude Code mutates
        # its own iTerm tab title while working (spinner/activity text), so a title-match miss does
        # NOT mean the executor died — treating it as death falsely marked live, idle, and even
        # already-reported sessions `dead`, which then made `relay send` refuse to reuse them. The
        # tab title is consulted ONLY once the process is already gone, to tell "crashed but tab
        # still open" (stalled — inspect it) from "tab closed too" (dead).
        # SHORTCUT: pid_alive() via os.kill can be fooled by PID reuse if the OS recycles this exact
        # pid to a different process before we poll; acceptable within a session's lifetime — revisit
        # with a process start-time / cmdline check if it ever bites.
        if report.exists():
            # A written report is a completed deliverable → reported, regardless of process/tab
            # state. Log the transition only once, not on every subsequent poll.
            if s["status"] != "reported":
                append_ledger("reported", session_id=session_id, packet=n)
            s["status"] = "reported"
        elif proc_alive:
            elapsed = _busy_elapsed(s)
            if s["status"] == "busy" and elapsed is not None and elapsed > _stall_threshold_seconds():
                s["status"] = "stalled"
                append_ledger("stalled", session_id=session_id, packet=n, reason=f"busy {int(elapsed/60)}min, no report")
            # else: process alive, hasn't reported yet → still busy, no change.
        else:
            # Process is genuinely gone and left no report. Distinguish stalled vs dead by whether
            # the tab is still around to look at (this is the ONLY place the tab-liveness check is
            # used).
            if term_backend(s).is_alive(s["tab_label"], s.get("iterm_session"), s.get("pid")):
                s["status"] = "stalled"
                append_ledger("stalled", session_id=session_id, packet=n, reason="process gone, no report; tab still open")
            else:
                s["status"] = "dead"
                append_ledger("closed", session_id=session_id, reason="process gone and tab closed")
        s["updated"] = now()
        write_session(session_id, s)

    return s


# ---- terminal color (TTY-aware; respects NO_COLOR; never colors piped/--json output) -----------
_ANSI = {"reset": "\033[0m", "bold": "\033[1m", "dim": "\033[2m",
         "green": "\033[32m", "yellow": "\033[33m", "red": "\033[31m"}
# status → styles. `reported` (an executor is DONE) is bright green+bold so it pops at a glance.
_STATUS_STYLE = {"reported": ("green", "bold"), "busy": ("yellow",), "stalled": ("red",),
                 "dead": ("dim", "red"), "closed": ("dim",), "superseded": ("dim",),
                 LAUNCH_FAILED: ("red", "bold")}  # needs action (relay restart) — as loud as reported


def _color_on():
    return sys.stdout.isatty() and not os.environ.get("NO_COLOR")


def c(text, *styles):
    if not styles or not _color_on():
        return text
    return "".join(_ANSI[s] for s in styles) + text + _ANSI["reset"]


def cmd_check(args):
    ids = all_session_ids() if args.all else [args.session_id]
    results = [_check_one(sid) for sid in ids if sid]
    for s in results:
        if "error" not in s:
            _mark_report_surfaced(s)  # the lead just looked at this report — dedup it (§5b)
    if args.json:
        print(json.dumps(results, indent=2))
        return
    for s in results:
        if "error" in s:
            print(f"{s['session_id']}: {c(s['error'], 'red')}")
            continue
        n = s["current_packet"]
        reported = (packets_dir(s["session_id"]) / f"{n:03d}-report.md").exists()
        status_c = c(s["status"], *_STATUS_STYLE.get(s["status"], ()))
        rep_c = c("✅ report ready", "green", "bold") if reported else c("not yet", "dim")
        print(f"{s['session_id']}: status={status_c} packet={n:03d} {rep_c}")


def _resolve_status_payload(args):
    """Priority order for `relay status`'s subject: an explicit positional id, then (only with
    --statusline) a JSON payload piped in on stdin, then $CLAUDE_CODE_SESSION_ID, else None.
    Garbage/non-JSON stdin degrades to "no id" rather than raising — a malformed statusline
    payload must not crash a status-line render. Returns (session_id, transcript_path) — the
    latter is only ever non-None when --statusline parsed a payload with a `transcript_path`
    field (positional-id / env-var invocations have no transcript to report on)."""
    sid = getattr(args, "session_id", None)
    transcript_path = None
    if not sid and getattr(args, "statusline", False):
        try:
            payload = json.loads(sys.stdin.read())
            if isinstance(payload, dict):
                sid = payload.get("session_id")
                transcript_path = payload.get("transcript_path")
        except Exception:
            sid = None
    return (sid or os.environ.get("CLAUDE_CODE_SESSION_ID") or None), transcript_path


def _weight_segment(state_root, lead_sid, transcript_path):
    """The transcript-size / handoff-awareness segment: ambient early warning before the one-shot
    handoff nudge (stop_lead_watch) fires, persistent pointer after. `transcript_path` is only
    ever set in --statusline mode (see _resolve_status_payload), so this is silent for positional-
    id/env-var invocations — there's no transcript to measure. Reuses lead_guard.transcript_mb/
    handoff_nudged rather than re-deriving either. Returns "" when there's nothing to say (below
    60% of the threshold, unnudged and mb <= 0, or handoff_nudge disabled in config)."""
    cfg = lead_guard.load_config(state_root)
    if not cfg.get("handoff_nudge", True):
        return ""
    mb = lead_guard.transcript_mb(transcript_path)
    threshold = float(cfg.get("handoff_nudge_mb", 5))
    nudged = lead_guard.handoff_nudged(state_root, lead_sid)
    if (mb >= threshold) or (nudged and mb > 0):
        return f"{mb:.1f}MB → /relay:handoff"
    if mb >= 0.6 * threshold:
        return f"{mb:.1f}MB"
    return ""


def _lead_status_line(lead_sid, marker, transcript_path=None):
    """The LEAD view: busy-executor NAMES (stored status busy, no report yet — a bare count doesn't
    tell you WHO, per live-usage feedback), reported-executor names (report file exists, status not
    closed/superseded — computed WITHOUT writing anything; report-file existence is only a
    display-time freshness upgrade over the stored status), a WAKE segment when this lead's
    auto-wake is unhealthy, and (--statusline mode only, when `transcript_path` is given) a
    transcript-weight segment. Reuses wake_hook_state/poll_lock_state/transcript_mb/handoff_nudged
    (lead_guard) rather than re-deriving their rules.

    ALWAYS leads with an armed/paused token, even for a lead with zero executors and nothing wrong.
    That is the whole point: "am I armed right now?" had no glanceable answer, so silent unarming
    went unnoticed for days (docs/lead-arming-durability.md). A blank status line must mean "not a
    lead", never "armed but quiet"."""
    if lead_guard.is_tombstoned(marker):
        # PAUSED: session exited but resumable. Not armed — gate and wake are OFF — so it would be
        # actively misleading to render executor/wake segments as though a live lead were watching.
        return f"⏸ {marker.get('project') or 'lead'} paused"

    busy = []
    reported = []
    for esid in all_session_ids():
        s = read_session(esid)
        if not s or s.get("owner_lead") != lead_sid:
            continue
        status = s.get("status")
        if status in ("closed", "superseded"):
            continue
        n = s.get("current_packet")
        report_exists = n is not None and (packets_dir(esid) / f"{n:03d}-report.md").exists()
        if report_exists:
            reported.append(esid)
        elif status == "busy":
            busy.append(esid)

    # Armed token first, unconditionally — an armed lead is never invisible.
    segments = [f"🚦 {marker.get('project') or 'lead'}"]
    if busy:
        shown = busy[:3]
        label = ",".join(shown)
        if len(busy) > 3:
            label += f" +{len(busy) - 3}"
        segments.append(f"🚦 busy: {label}")
    if reported:
        shown = reported[:3]
        label = ",".join(shown)
        if len(reported) > 3:
            label += f",+{len(reported) - 3}"
        segments.append(f"✅ {label}")

    cfg = lead_guard.load_config(STATE_ROOT)
    poll_seconds = cfg.get("poll_seconds", 1800)
    poll_interval = cfg.get("poll_interval", 5)
    if lead_guard.poll_lock_state(STATE_ROOT, lead_sid, poll_interval) == "stale":
        segments.append("WAKE stuck")
    elif lead_guard.wake_hook_state(marker, poll_seconds) == "stale":
        segments.append("WAKE stale")

    if transcript_path:
        weight = _weight_segment(STATE_ROOT, lead_sid, transcript_path)
        if weight:
            segments.append(weight)

    return " · ".join(segments)


def _executor_status_line(s):
    """The EXECUTOR view: current packet + state (report-file existence upgrades the stored status
    to "✅ reported", read-only) and, when owned, the owning lead's project name as "for <project>"
    ("lead: <project>" read ambiguously in an executor tab — whose role is 'lead' here?). No
    "→ overall: lead tab" tail — live usage feedback called it noise; an unowned executor just
    shows pkt+state, nothing else to point at."""
    n = s["current_packet"]
    report_exists = (packets_dir(s["session_id"]) / f"{n:03d}-report.md").exists()
    state = "✅ reported" if report_exists else s.get("status", "?")

    owner_lead = s.get("owner_lead")
    if not owner_lead:
        return f"🚦 pkt {n:03d} {state}"
    marker = lead_guard.read_marker(STATE_ROOT, owner_lead)
    label = (marker.get("project") if marker else None) or f"{owner_lead[:8]}…"
    return f"🚦 pkt {n:03d} {state} · for {label}"


def cmd_status(args):
    """Strictly read-only, statusline-safe one-liner. NO writes anywhere in this path — no
    write_session, no append_ledger, no _check_one, no marker touches — so it's safe to call on
    every status-line render (potentially many times a minute). `relay list`/`relay check` remain
    the decision surface: they refresh real liveness by mutating state; this command only reads
    markers + session.json as they already are and checks report-file existence. Prints nothing for
    a session id that's neither a lead nor a known executor — an unrelated session's status line
    must not grow relay noise."""
    sid, transcript_path = _resolve_status_payload(args)
    if not sid:
        return

    marker = lead_guard.read_marker(STATE_ROOT, sid)
    if marker:
        line = _lead_status_line(sid, marker, transcript_path)
        if line:
            print(line)
        return

    # Executor lookup, both id spaces: the RELAY session id first (what a human types —
    # `relay status tk-auth`), then the pinned Claude conversation id (what the --statusline
    # payload carries — a session only knows its own Claude id). Missing either lookup silently
    # blanks a real executor for one caller class; both observed live.
    s = read_session(sid)
    if s:
        print(_executor_status_line(s))
        return
    for esid in all_session_ids():
        s = read_session(esid)
        if s and s.get("claude_session") == sid:
            print(_executor_status_line(s))
            return


def _lead_age_cell(m):
    """LAST ACTIVE cell for a lead row, prefixed with ⏸ when the lead is PAUSED (tombstoned: its
    session exited but is resumable, so it is NOT armed right now). Without this a paused lead
    renders identically to a live one, which is precisely the silent state this mechanism exists to
    eliminate."""
    age = _relative_age(m.get("last_active"))
    return f"⏸ {age}" if lead_guard.is_tombstoned(m) else age


def _relative_age(ts):
    """A short relative age ('30s ago' / '12m ago' / '2h ago' / '3d ago') from an ISO timestamp in
    now()'s format. Degrades to '-' when ts is missing/None or in an unparseable/old format — a
    stale-looking (or dashed) LAST ACTIVE is how a human spots a probably-crashed lead, so this
    must never crash the list."""
    if not ts:
        return "-"
    try:
        then = time.mktime(time.strptime(ts, "%Y-%m-%dT%H:%M:%S"))
    except Exception:
        return "-"
    secs = int(time.mktime(time.localtime()) - then)
    if secs < 0:
        secs = 0
    if secs < 60:
        return f"{secs}s ago"
    mins = secs // 60
    if mins < 60:
        return f"{mins}m ago"
    hours = mins // 60
    if hours < 24:
        return f"{hours}h ago"
    return f"{hours // 24}d ago"


def cell(text, width):
    """Fixed-width table cell: pad short values, truncate long ones with a trailing ellipsis
    so a single oversized value can never shift the columns after it."""
    s = str(text) if text not in (None, "") else "-"
    return (s[: width - 1] + "…") if len(s) > width else s.ljust(width)


def _lead_auto_cell(m):
    """`relay list`'s AUTO cell for one lead marker: `(text, styles)`, same shape as _WAKE_CELL's
    entries. "AUTO" in bold yellow when this lead proceeds without asking, a dim "-" when it holds
    the ordinary wait-for-human posture — the loud/quiet asymmetry is the point (§6f: a
    proceeded-without-you lead must be MORE visible, not less)."""
    on, _source = lead_guard.autonomous_state(m)
    return ("AUTO", ("yellow", "bold")) if on else ("-", ("dim",))


def _lead_term_cell(m):
    """`relay list`'s TERM cell for one lead marker: which terminal app hosts its tab. A dim "?"
    means the marker has no recorded `backend`, so every nudge to that lead has to fall back to
    _probe_backend_for_tab — which only resolves when exactly one backend has a matching tab, and
    otherwise degrades to the caller's ambient guess (§1, Defect A). Rendering it makes that
    degraded state visible instead of something you only find by reading marker JSON."""
    return m.get("backend") or "?"


def _lead_stamp_fresh(m, now_ts=None):
    """Whether marker `m`'s last_active is parseable and within LEAD_LIVE_WINDOW_SECONDS — the
    same "fresh" test unique_lead_project uses to decide whether a name is still reserved (§3).
    An unparseable/missing stamp degrades to False (not fresh), mirroring that convention."""
    now_ts = time.time() if now_ts is None else now_ts
    try:
        last_active = time.mktime(time.strptime(m.get("last_active") or "", "%Y-%m-%dT%H:%M:%S"))
    except Exception:
        return False
    return (now_ts - last_active) <= LEAD_LIVE_WINDOW_SECONDS


def _lead_liveness(m, now_ts=None):
    """§3's liveness verdict for one lead marker — 'live' / 'unreachable' / 'ghost':

      'live'        — the tab is still alive (term_backend(m).is_alive, the same tab-title/handle
                       probe executors use via _check_one — see docstring there). A live tab is
                       'live' regardless of stamp freshness: an idle lead waiting on the human can
                       legitimately go quiet past LEAD_LIVE_WINDOW_SECONDS without being dead.
      'unreachable' — tab NOT alive, but last_active is still fresh. This is the valuable case §3
                       calls out: a lead that crashed moments ago and hasn't aged into obvious
                       staleness yet (the alpha_service failure — invisible until someone looked).
      'ghost'       — tab not alive AND the stamp is beyond the window (or unparseable/missing) —
                       the beta_view case: dead for days, never stepped down, never tombstoned.

    Pure and fail-open: any is_alive probe exception is treated as "not alive" (surface the
    degraded state rather than hiding it behind a crash)."""
    try:
        alive = term_backend(m).is_alive(m.get("tab_label"), m.get("iterm_session"), None)
    except Exception:
        alive = False
    if alive:
        return "live"
    return "unreachable" if _lead_stamp_fresh(m, now_ts) else "ghost"


_LIVENESS_CELL = {"live": ("live", ("green",)), "unreachable": ("unreachable", ("red", "bold")),
                  "ghost": ("ghost", ("dim", "red"))}


def _lead_liveness_cell(m):
    """`relay list`'s LIVE cell for one lead marker: `(text, styles)`, same shape as _WAKE_CELL's
    entries. 'unreachable' is styled as loud as a stale WAKE warning — it is the state a dead lead
    used to hide behind ("indistinguishable from an idle one", §3) — while 'ghost' is dim (already
    long gone, nothing urgent to act on beyond eventual `relay prune`)."""
    return _LIVENESS_CELL[_lead_liveness(m)]


def _find_transcript_path(claude_session):
    """First matching transcript JSONL for `claude_session`, scanning the same project dirs as
    conversation_transcript_exists (see _transcript_project_dirs). Returns a Path, or None when
    the projects root is unreadable/empty or nothing matches — callers render '-' for either case,
    so there is no need to distinguish "unknowable" from "not found" here."""
    for d in (_transcript_project_dirs() or []):
        p = d / f"{claude_session}.jsonl"
        if p.exists():
            return p
    return None


def _lead_mb_cell(m):
    """`relay list`'s MB cell (§9's "cheap sibling" to §3): this lead's OWN transcript size, read
    straight from disk rather than the --statusline payload (list has no payload to read — this
    runs from any shell, not necessarily the lead's own). '-' when the transcript can't be
    located — never guesses, never crashes — which also covers the legacy-marker case (no
    session_id at all)."""
    sid = m.get("session_id")
    path = _find_transcript_path(sid) if sid else None
    if not path:
        return "-"
    return f"{lead_guard.transcript_mb(str(path)):.1f}"


def cmd_list(args):
    # LEADS are ALWAYS shown in full — you always want to see/restore any project, regardless of
    # which lead is asking. Executor scoping is separate (below).
    leads = lead_guard.list_leads(STATE_ROOT)

    lead_sid = getattr(args, "lead", None)
    # --all (or no --lead at all) → every executor (back-compat). --lead <sid> → only executors
    # owned by that lead, PLUS unowned ones (owner_lead is None). Unowned are always visible.
    show_all = getattr(args, "all", False) or not lead_sid

    rows = []
    for sid in all_session_ids():
        # Refresh REAL liveness (same mechanism as `relay check`) — list is the decision-informing
        # and crash-recovery surface, so a dead/stalled executor must not keep showing stored `busy`.
        s = _check_one(sid)
        if "error" in s:
            continue
        n = s["current_packet"]
        report = packets_dir(sid) / f"{n:03d}-report.md"
        rows.append({**s, "reported": report.exists()})
    if not show_all:
        rows = [s for s in rows if s.get("owner_lead") in (None, lead_sid)]

    # Orphans: live executors (among the rows this invocation is about to display) owned by a lead
    # that's no longer armed (marker gone) — the wake-loss bug's blind spot.
    # LAUNCH_FAILED is excluded alongside the terminal states: nothing is running to lose a wake,
    # and the orphan line's "just relay send/resume, which adopt automatically" advice is wrong for
    # it (both refuse — `relay restart` is its only route back).
    orphans = [s for s in rows if s["status"] not in ("closed", "superseded", "dead", LAUNCH_FAILED)
               and s.get("owner_lead") and not lead_guard.read_marker(STATE_ROOT, s["owner_lead"])]

    if args.json:
        # --json: fully unfiltered (programmatic surface, filtering is human-display concern)
        print(json.dumps({"leads": leads, "executors": rows}, indent=2))
        return

    # Separate live and terminal rows for filtering
    terminal_statuses = {"closed", "superseded", "dead"}
    live_rows = [s for s in rows if s["status"] not in terminal_statuses]
    terminal_rows = [s for s in rows if s["status"] in terminal_statuses]
    hidden_terminal_count = 0

    # --closed: include terminal rows, cap at 15 most recent
    if getattr(args, "closed", False):
        # Sort terminal rows by updated (most recent first)
        terminal_rows_sorted = sorted(terminal_rows, key=lambda s: s.get("updated", ""), reverse=True)
        shown_terminal = terminal_rows_sorted[:15]
        hidden_terminal = terminal_rows_sorted[15:]
        rows = live_rows + shown_terminal
        hidden_terminal_count = len(hidden_terminal)
    else:
        # Default: exclude all terminal rows
        rows = live_rows
        hidden_terminal_count = len(terminal_rows)

    if leads:
        print(c("LEADS", "bold"))
        # WAKE: is each lead's background wake poller safe from an early harness kill? Read from the
        # Stop-hook timeout stamped in the marker at arm time (see lead_guard.wake_hook_state). "stale"
        # is the silent missed-wake bug made visible — a lead bound to a pre-fix hook gets back on the
        # fixed one by /reload-plugins then re-running /relay:mode (re-arms + re-stamps); the stamp
        # only refreshes on re-arm, which is why an updated-but-not-re-armed lead can still read stale.
        lead_cfg = lead_guard.load_config(STATE_ROOT)
        poll_seconds = lead_cfg.get("poll_seconds", 1800)
        poll_interval = lead_cfg.get("poll_interval", 5)
        wake_states = {}
        for m in leads:
            sid = m.get("session_id")
            state = lead_guard.wake_hook_state(m, poll_seconds)
            # "stuck" overrides ok/stale/ver?: a dead watcher's lock blocking wakes is a distinct,
            # more urgent condition than a pre-fix hook timeout — surfaced via the SAME staleness
            # definition acquire_poll_lock uses (lead_guard.poll_lock_state), so list and acquire
            # never diverge on what counts as stale.
            if lead_guard.poll_lock_state(STATE_ROOT, sid, poll_interval) == "stale":
                state = "stuck"
            wake_states[sid] = state
        _WAKE_CELL = {"ok": ("ok", ("green",)), "stale": ("STALE", ("red", "bold")),
                      "unknown": ("ver?", ("dim",)), "stuck": ("stuck", ("red", "bold"))}
        # One liveness verdict per lead, computed up front — see the LIVE column comment below.
        liveness_by_sid = {m.get("session_id"): _lead_liveness(m) for m in leads}
        # Calculate dynamic widths for LEADS table with per-column caps.
        lead_cols = [
            ("PROJECT", 22, [m.get("project") or "-" for m in leads]),
            ("SESSION", 36, [m.get("session_id") or "-" for m in leads]),
            ("MODEL", 8, [m.get("model") or "-" for m in leads]),
            ("VER", 8, [m.get("plugin_version") or "?" for m in leads]),
            ("WAKE", 5, [_WAKE_CELL[wake_states[m.get("session_id")]][0] for m in leads]),
            # AUTO: which leads are proceeding WITHOUT asking (§6f). Autonomy must not become
            # silence — a lead acting on its own has to be MORE visible here, not less — so an auto
            # lead gets a loud stamp while the ordinary manual posture renders as a quiet dash.
            ("AUTO", 4, [_lead_auto_cell(m)[0] for m in leads]),
            # TERM: which terminal app hosts this lead's tab, from its marker. "?" = unrecorded, so
            # nudges to it are probe-or-guess rather than addressed (§1) — the same "you can only
            # find this by reading JSON" blind spot the VER/WAKE cells already exist to remove.
            ("TERM", 8, [_lead_term_cell(m) for m in leads]),
            # LIVE: §3's honest liveness verdict (live/unreachable/ghost) — before this, a dead
            # lead with no clean step-down was indistinguishable from an idle one. Computed ONCE
            # per lead here (liveness_by_sid): each verdict runs a real is_alive osascript probe,
            # and this table needs it in four places (sizing, row, two footnotes) — re-probing
            # would add 4×N subprocess round-trips to every `relay list`.
            ("LIVE", 11, [_LIVENESS_CELL[liveness_by_sid[m.get("session_id")]][0] for m in leads]),
            # MB: §9's cheap sibling to §3 — this lead's own transcript size, so a heavy session is
            # a visible climbing number all day rather than a surprise at the handoff nudge.
            ("MB", 6, [_lead_mb_cell(m) for m in leads]),
            ("LAST ACTIVE", 12, [_lead_age_cell(m) for m in leads]),
        ]
        lead_widths = {name: min(cap, max(len(name), max((len(str(v)) for v in vals), default=0)))
                       for name, cap, vals in lead_cols}
        # Header row with dynamic widths
        header_parts = [cell(name, lead_widths[name]) for name, _, _ in lead_cols]
        print(" ".join(header_parts))
        # Data rows
        for m in leads:
            wake_text, wake_styles = _WAKE_CELL[wake_states[m.get("session_id")]]
            auto_text, auto_styles = _lead_auto_cell(m)
            term_text = _lead_term_cell(m)
            live_text, live_styles = _LIVENESS_CELL[liveness_by_sid[m.get("session_id")]]
            row_parts = [
                cell(m.get("project") or "-", lead_widths["PROJECT"]),
                cell(m.get("session_id") or "-", lead_widths["SESSION"]),
                cell(m.get("model") or "-", lead_widths["MODEL"]),
                cell(m.get("plugin_version") or "?", lead_widths["VER"]),
                c(cell(wake_text, lead_widths["WAKE"]), *wake_styles),
                c(cell(auto_text, lead_widths["AUTO"]), *auto_styles),
                # A recorded backend is unremarkable; an unrecorded one is the degraded state, so
                # only the "?" gets styling (dim — informational, not an error).
                cell(term_text, lead_widths["TERM"]) if term_text != "?"
                else c(cell(term_text, lead_widths["TERM"]), "dim"),
                c(cell(live_text, lead_widths["LIVE"]), *live_styles),
                cell(_lead_mb_cell(m), lead_widths["MB"]),
                cell(_lead_age_cell(m), lead_widths["LAST ACTIVE"]),
            ]
            print(" ".join(row_parts))
        # A paused lead looks identical to a live one without this — and "silently not armed" is the
        # exact failure this whole mechanism exists to end (docs/lead-arming-durability.md).
        if any(lead_guard.is_tombstoned(m) for m in leads):
            print(c("  ⏸ paused: this lead's session exited but is resumable — its name and state "
                    "are held, and resuming re-arms it automatically.", "dim"))
        # Footnote only when something needs action — a stale (or unknown) wake hook is exactly the
        # silent condition that used to cost a forensic investigation to find.
        # Autonomy must never be quiet: if any lead is proceeding without asking, say so in words
        # right here, not only as a four-character column a skimming eye slides past.
        auto_leads = [m for m in leads if lead_guard.autonomous_state(m)[0]]
        if auto_leads:
            names = ", ".join((m.get("project") or (m.get("session_id") or "?")[:8]) for m in auto_leads)
            print(c(f"  ⚡ AUTO: {names} — proceeding without asking on routine in-plan steps. "
                    f"Committing executor work still stops for you. `relay auto off --session <id>` "
                    f"reverts.", "yellow"))
        # LIVE=unreachable/ghost footnotes (§3) — the same "say it in words, not just a cell" rule
        # the AUTO/WAKE warnings already follow, since a skimmed column is easy to slide past.
        unreachable_leads = [m for m in leads if liveness_by_sid[m.get("session_id")] == "unreachable"]
        if unreachable_leads:
            names = ", ".join((m.get("project") or (m.get("session_id") or "?")[:8]) for m in unreachable_leads)
            print(c(f"  ⚠ LIVE=unreachable: {names} — recently active but its tab can no longer be "
                    f"reached (crashed or closed without stepping down). Check on it directly.",
                    "red"))
        ghost_leads = [m for m in leads if liveness_by_sid[m.get("session_id")] == "ghost"]
        if ghost_leads:
            names = ", ".join((m.get("project") or (m.get("session_id") or "?")[:8]) for m in ghost_leads)
            print(c(f"  ⚠ LIVE=ghost: {names} — tab gone, stamp stale — this lead is dead and never "
                    f"stepped down. `relay close --self <session-id>` clears it (or `relay prune`).",
                    "dim"))
        if any(st == "stuck" for st in wake_states.values()):
            print(c("  ⚠ WAKE=stuck: a dead watcher's lock is blocking wakes for this lead — it "
                    "will self-heal on the lead's next turn (the lock is now auto-broken), and any "
                    "landed report surfaces then.", "red"))
        if any(st == "stale" for st in wake_states.values()):
            print(c("  ⚠ WAKE=STALE: this lead's auto-wake hook predates the timeout fix — it will "
                    "MISS late executor reports.", "red"))
            print(c("    Fix: update relay if needed (/plugin update relay@claude-relay), /reload-plugins, "
                    "then re-run /relay:mode to re-arm on the fixed hook (or restart the session).", "red"))
        elif any(st == "unknown" for st in wake_states.values()):
            print(c("  ⚠ WAKE=ver?: armed before version stamping — re-run /relay:mode to re-stamp; if it "
                    "predates your last relay update, /reload-plugins first (or restart).", "dim"))
        # Stale-hooks detection (wake bug #3): current hooks (>=0.3.10) re-stamp the marker's
        # version on EVERY lead turn — so a RECENTLY-ACTIVE lead whose stamp is still older than
        # the installed version proves its session is executing old hook code (/reload-plugins
        # didn't re-point it). The one thing that defeats this tell is a manual /relay:mode
        # re-stamp on top of stale hooks, hence the warning's last clause. Inactive leads are
        # skipped (no recent turn = no re-stamp expected = no signal either way).
        installed = _version_tuple(plugin_version())
        if installed:
            stale_hooks = []
            for m in leads:
                stamped = _version_tuple(m.get("plugin_version"))
                if not stamped or stamped >= installed:
                    continue
                try:
                    age = time.time() - time.mktime(time.strptime(m.get("last_active", ""),
                                                                  "%Y-%m-%dT%H:%M:%S"))
                except Exception:
                    continue  # unknown activity → no signal, stay quiet
                if age < 6 * 3600:  # active recently enough that current hooks would have re-stamped
                    stale_hooks.append(m.get("project") or (m.get("session_id") or "?")[:8])
            if stale_hooks:
                print(c(f"  ⚠ stale hooks: {', '.join(stale_hooks)} — active but still stamped older "
                        f"than the installed {plugin_version()}, so /reload-plugins did NOT re-point "
                        f"that session's hooks. Restart it (a manual /relay:mode re-stamp only hides "
                        f"this warning).", "red"))
        print()

    print(c("EXECUTORS", "bold"))
    if not rows:
        print("(no executor sessions)")
        return
    # Build rendered status strings once to use both in width calc and row rendering.
    rendered_statuses = []
    for s in rows:
        st = s["status"]
        if st == "busy":
            elapsed = _busy_elapsed(s)
            st = f"busy {int(elapsed / 60)}m" if elapsed is not None else "busy ?"
        rendered_statuses.append(st)
    # Calculate dynamic widths for EXECUTORS table with per-column caps.
    exec_cols = [
        ("SESSION", 36, [s["session_id"] for s in rows]),
        ("STATUS", len(LAUNCH_FAILED), rendered_statuses),  # cap fits the longest status verbatim —
                                                            # a truncated "launch-fai" defeats the point
        ("TOPIC", 40, [s["topic"] for s in rows]),
        ("SCOPE", 14, [s.get("scope", "") or "-" for s in rows]),
        ("PROJECT", 14, [str(s.get("owner_project") or "-") for s in rows]),
        ("MODEL", 8, [str(s.get("model") or "-") for s in rows]),
        ("PKT", 4, [str(s["current_packet"]).zfill(4) for s in rows]),
        ("REPORTED", 8, ["yes" if s["reported"] else "no" for s in rows]),
    ]
    exec_widths = {name: min(cap, max(len(name), max((len(str(v)) for v in vals), default=0)))
                   for name, cap, vals in exec_cols}
    # Header row with dynamic widths
    header_parts = [cell(name, exec_widths[name]) for name, _, _ in exec_cols]
    print(" ".join(header_parts))
    # Data rows
    for i, s in enumerate(rows):
        base = s["status"]
        status = rendered_statuses[i]
        # Color the padded cell (pad first via cell(), then wrap — ANSI codes have zero display width,
        # so padding before c() keeps the columns aligned).
        status_cell = c(cell(status, exec_widths["STATUS"]), *_STATUS_STYLE.get(base, ()))
        rep = "yes" if s["reported"] else "no"
        rep_cell = c(cell(rep, exec_widths["REPORTED"]), "green", "bold") if s["reported"] else c(cell(rep, exec_widths["REPORTED"]), "dim")
        row_parts = [
            cell(s["session_id"], exec_widths["SESSION"]),
            status_cell,
            cell(s["topic"], exec_widths["TOPIC"]),
            cell(s.get("scope", "") or "-", exec_widths["SCOPE"]),
            cell(str(s.get("owner_project") or "-"), exec_widths["PROJECT"]),
            cell(str(s.get("model") or "-"), exec_widths["MODEL"]),
            cell(str(s["current_packet"]).zfill(4), exec_widths["PKT"]),
            rep_cell,
        ]
        print(" ".join(row_parts))

    if orphans:
        sids = ", ".join(s["session_id"] for s in orphans)
        print(c(f"  ⚠ {len(orphans)} executor(s) owned by retired leads (wake won't fire): {sids} — "
                f"reclaim with relay adopt <sid> (or just relay send/resume, which adopt "
                f"automatically).", "yellow"))

    # Print footer if terminal sessions are hidden/truncated
    if getattr(args, "closed", False) and hidden_terminal_count > 0:
        # --closed with more than 15 terminal rows: show how many older ones exist
        footer = f"(…and {hidden_terminal_count} older closed sessions — `relay prune --dry-run`)"
        print(c(footer, "dim"))
    elif not getattr(args, "closed", False) and hidden_terminal_count > 0:
        # Default: show how many terminal rows are hidden
        footer = f"(+{hidden_terminal_count} closed/superseded/dead hidden — `relay list --closed` to show, `relay prune --dry-run` to see what's clearable)"
        print(c(footer, "dim"))


def _has_staged_diff(worktree):
    """True iff `worktree` has a non-empty `git diff --staged` — cheap discoverability check for
    cmd_report's diff-pointer line; doesn't generate anything, just asks git. Any error (not a
    git repo, worktree gone) → False, never raises."""
    try:
        r = subprocess.run(["git", "-C", worktree, "diff", "--staged", "--quiet"])
        return r.returncode == 1
    except Exception:
        return False


def cmd_report(args):
    """Print an executor's report framed in a bright green banner — so it's unmistakably THE
    report, and done. Defaults to the session's current packet."""
    s = read_session(args.session_id)
    if not s:
        sys.exit(f"no such session: {args.session_id}")
    n = args.packet or s["current_packet"]
    rp = packets_dir(args.session_id) / f"{n:03d}-report.md"
    if not rp.exists():
        sys.exit(f"no report yet for '{args.session_id}' packet {n:03d}")
    bar = "═" * 74
    print(c(bar, "green", "bold"))
    print(c(f"  ✅ REPORT READY   ·   {args.session_id}   ·   packet {n:03d}", "green", "bold"))
    print(c(f"  {rp}", "dim"))
    print(c(bar, "green", "bold"))
    print(rp.read_text().rstrip())
    print(c(bar, "green", "bold"))
    if s.get("worktree") and _has_staged_diff(s["worktree"]):
        print(c(f"  📄 review the staged diff: relay diff {args.session_id} --open", "dim"))


def cmd_diff(args):
    """Render an executor's staged changes to a self-contained HTML review page (diff_render.py)
    — one click, zero model tokens. Default scope is the files mentioned in the session's CURRENT
    packet report (best-effort file:line / bare-path parsing); `--all` bypasses that and renders
    the whole staged diff. If the report is missing or none of its mentions match anything
    actually staged, this falls back to the full staged diff with a visible in-page note —
    scoping never fails the command outright."""
    s = read_session(args.session_id)
    if not s:
        sys.exit(f"no such session: {args.session_id}")
    worktree = s.get("worktree")
    if not worktree:
        sys.exit(f"session '{args.session_id}' has no recorded worktree")
    n = s.get("current_packet", 1)
    report_path = packets_dir(args.session_id) / f"{n:03d}-report.md"
    _mark_report_surfaced(s)  # the lead is reviewing this report's diff — dedup it (§5b)

    staged = subprocess.run(["git", "-C", worktree, "diff", "--staged", "--name-only"],
                            capture_output=True, text=True)
    staged_names = [ln.strip() for ln in staged.stdout.splitlines() if ln.strip()]

    scope_note = ""
    scope_files = None
    if not args.all:
        if report_path.exists():
            mentioned = set(diff_render.parse_report_mentions(report_path.read_text()))
            scope_files = [f for f in staged_names if f in mentioned]
            if not scope_files:
                scope_note = "unfiltered — report not found/parsable"
        else:
            scope_note = "unfiltered — report not found/parsable"

    diff_cmd = ["git", "-C", worktree, "diff", "--staged"]
    if scope_files:
        diff_cmd += ["--", *scope_files]
    diff_text = subprocess.run(diff_cmd, capture_output=True, text=True).stdout

    meta = {"session_id": args.session_id, "packet": n, "scope_note": scope_note}
    page = diff_render.generate_page(diff_text, meta)

    out_path = packets_dir(args.session_id) / f"{n:03d}-diff.html"
    out_path.write_text(page)
    print(str(out_path))
    print(path_to_file_url(out_path))
    if args.open:
        subprocess.run(["open", str(out_path)])


def cmd_close(args):
    # No positional session_id → "step down from lead mode for THIS session" (needs --self, the
    # current session's own id, since a bare CLI invocation has no ambient session identity).
    # This is distinct from closing an EXECUTOR session, which still takes a positional session_id.
    if not args.session_id:
        if not args.self_session:
            sys.exit("close: give an executor session_id to close it, or --self <session_id> to step down from lead mode")
        lead_guard.clear_lead(STATE_ROOT, args.self_session)
        append_ledger("lead_stepped_down", session_id=args.self_session)
        print(f"stepped down from lead mode (session '{args.self_session}')")
        return

    s = read_session(args.session_id)
    if not s:
        sys.exit(f"no such session: {args.session_id}")
    _mark_report_surfaced(s)  # the lead is done with this executor's report — dedup it (§5b)
    if args.supersede:
        s["status"] = "superseded"
        s["superseded_by"] = args.supersede
        append_ledger("superseded", session_id=args.session_id, superseded_by=args.supersede)
    else:
        s["status"] = "closed"
        append_ledger("closed", session_id=args.session_id, reason="manual close")
    s["updated"] = now()
    write_session(args.session_id, s)

    # Close the executor's iTerm tab too (we're done with it; its report is on disk, nothing lost).
    # Kill the process FIRST so iTerm doesn't prompt "confirm close running process", give it a beat
    # to die, then close. Best-effort — a failure here still leaves the session marked closed.
    tab_note = ""
    if not getattr(args, "keep_tab", False):
        bk = term_backend(s)
        _kill_and_wait(s)  # start-time-checked inside: never SIGTERM an unrelated recycled pid
        closed_tab = bk.close(s.get("tab_label", ""), s.get("iterm_session"), s.get("pid"))
        if closed_tab:
            tab_note = " + closed its tab"
        elif not bk.is_alive(s.get("tab_label", ""), s.get("iterm_session"), s.get("pid")):
            # iTerm auto-closes a session's tab when its exec'd process dies — close() then finds
            # nothing, which is success, not a lingering tab (spurious Cmd-W note observed live).
            tab_note = " (tab closed itself)"
        else:
            # Terminal.app ignores scripted window-close on some macOS versions (verified no-op,
            # no error) — the process is dead either way; the lingering window is a Cmd-W away.
            tab_note = " (tab not auto-closed — Cmd-W it if it lingers)"
    print(f"closed session '{args.session_id}'"
          + (f" (superseded by {args.supersede})" if args.supersede else "") + tab_note)


def cmd_stop(args):
    """Step down from lead mode for THIS session (unarm). A discoverable alias for `relay close --self`
    — same effect, shorter name."""
    if not args.session_id:
        sys.exit("stop: session_id is required\nUsage: relay stop <session_id>")
    if lead_guard.is_lead(STATE_ROOT, args.session_id) is False:
        print(f"session '{args.session_id}' is not in lead mode — nothing to stop")
        return
    lead_guard.clear_lead(STATE_ROOT, args.session_id)
    append_ledger("lead_stepped_down", session_id=args.session_id)
    print(f"lead mode stopped for session '{args.session_id}' — gate and auto-wake are off")


def cmd_prune(args):
    """Delete the state dirs of terminal-status sessions (closed/superseded/dead) whose last update
    is older than --days, AND dead lead markers ("ghosts": tabs closed/crashed without /relay:stop,
    so the SessionEnd hook never fired to clean up) older than the same cutoff. Nothing else is
    touched: live sessions, live leads, and the sessions.jsonl ledger (the durable history) all
    stay. Without this, ~/.relay-tasks grows forever and every `check --all`/`list` iterates dead
    weight, and dead leads sit in the LEADS table forever with a permanent ver? warning."""
    cutoff = time.time() - args.days * 86400
    removed, kept = [], 0
    for sid in all_session_ids():
        s = read_session(sid)
        if s.get("status") not in ("closed", "superseded", "dead"):
            continue
        try:
            updated = time.mktime(time.strptime(s.get("updated", ""), "%Y-%m-%dT%H:%M:%S"))
        except Exception:
            updated = 0  # unparseable/missing → treat as ancient, prunable
        if updated > cutoff:
            kept += 1
            continue
        if not args.dry_run:
            shutil.rmtree(session_dir(sid), ignore_errors=True)
            append_ledger("pruned", session_id=sid, status=s.get("status"))
        removed.append(f"{sid} ({s.get('status')})")

    # Lead ghosts: a wrongly-dead verdict here DELETES lead state (unarms gate + wake for that
    # session if it ever comes back), which is worse than a stale row — hence the triple guard
    # below (never-self, liveness probe, AND staleness window). Unlike executor adoption, where
    # fail-toward-adoptable is the right direction, none of these three conditions may be weakened.
    caller = os.environ.get("CLAUDE_CODE_SESSION_ID")
    removed_leads = []
    for m in lead_guard.list_leads(STATE_ROOT):
        sid = m.get("session_id")
        if not sid or sid == caller:  # never prune the calling lead, even if it somehow probes dead
            continue
        if _lead_alive(sid):
            continue
        try:
            stamp = m.get("last_active") or m.get("started") or ""
            last_active = time.mktime(time.strptime(stamp, "%Y-%m-%dT%H:%M:%S"))
        except Exception:
            last_active = 0  # unparseable/missing → treat as ancient, same convention as above
        if last_active > cutoff:
            kept += 1
            continue
        if not args.dry_run:
            lead_guard.clear_lead(STATE_ROOT, sid)
            append_ledger("lead_pruned", session_id=sid, project=m.get("project"))
        stale_days = int((time.time() - last_active) / 86400) if last_active else "?"
        removed_leads.append(f"[lead] {m.get('project') or sid} ({sid[:8]}…, {stale_days}d stale)")

    verb = "would prune" if args.dry_run else "pruned"
    if removed or removed_leads:
        print(f"{verb} {len(removed) + len(removed_leads)} session(s):")
        for r in removed:
            print(f"  {r}")
        for r in removed_leads:
            print(f"  {r}")
    else:
        print(f"nothing to prune (terminal sessions newer than {args.days}d: {kept})")


# How long a lead's last_active stamp counts as "plausibly still live" for the purpose of reserving
# its project name (see unique_lead_project). Too short and two genuinely-live-but-idle leads could
# momentarily collide on a name; too long and a crashed lead's name stays reserved (and a stale
# ghost sitting in the same folder makes every re-arm creep the suffix) long after it's gone. 15
# minutes comfortably outlasts normal idle gaps between turns while still reclaiming crashed names
# well within a session.
LEAD_LIVE_WINDOW_SECONDS = 900


def unique_lead_project(project, self_sid, exclude_sids, leads, now_ts=None):
    """Resolve `project` to a name no other LIVE lead currently holds, auto-suffixing with the
    smallest free `-N` (N >= 2) on collision. `leads` is the list of marker dicts (as returned by
    `lead_guard.list_leads`); a marker reserves its name only if its session_id is neither
    `self_sid` (idempotent re-arm must keep the same name) nor in `exclude_sids` (a handoff
    successor passes its predecessor's id here, since succession intentionally inherits the name),
    AND its `last_active` parses and is within LEAD_LIVE_WINDOW_SECONDS of `now_ts` — an
    unparseable/missing stamp, or one older than the window, is treated as a ghost and never
    reserves its name, mirroring the existing "unparseable → ancient" convention used elsewhere in
    this file for lead pruning.

    Returns `(resolved_project, clashing_sid)` — `clashing_sid` is the session_id of the live lead
    that holds the *exact* `project` name (for the caller's NOTE), or None when `project` was
    already free (the common case, including reclaiming a name whose only holder is a ghost).

    Pure and fail-open by design: any exception degrades to returning `project` unchanged — a bug
    in this uniqueness check must never prevent a lead from arming."""
    try:
        now_ts = time.time() if now_ts is None else now_ts
        exclude = set(exclude_sids or ()) | {self_sid}
        reserved = {}  # project name -> session_id of the first (oldest) live lead holding it
        for m in leads:
            sid = m.get("session_id")
            name = m.get("project")
            if not sid or not name or sid in exclude:
                continue
            if lead_guard.is_tombstoned(m):
                # A tombstoned lead is PAUSED, not dead — it will be revived under its own name on
                # resume, so it keeps holding that name (docs/lead-arming-durability.md §9.2).
                # Without this, quitting and resuming could hand your name to someone else and bring
                # you back as "<project>-2". Deliberately different from the ghost rule below: a
                # ghost never announced an intent to return, a tombstone did.
                reserved.setdefault(name, sid)
                continue
            try:
                last_active = time.mktime(time.strptime(m.get("last_active") or "", "%Y-%m-%dT%H:%M:%S"))
            except Exception:
                continue  # unparseable/missing last_active → ghost, doesn't reserve
            if now_ts - last_active > LEAD_LIVE_WINDOW_SECONDS:
                continue  # stale → ghost, doesn't reserve
            reserved.setdefault(name, sid)
        if project not in reserved:
            return project, None
        n = 2
        while f"{project}-{n}" in reserved:
            n += 1
        return f"{project}-{n}", reserved[project]
    except Exception:
        return project, None


def cmd_lead_start(args):
    """Mark THIS session as a lead (invoked by /relay:mode). The marker's existence is what every
    hook checks to decide whether to act — so non-lead/executor sessions stay completely untouched.
    Idempotent: re-running /relay:mode just refreshes the marker."""
    if not args.session_id:
        sys.exit("lead-start: session id is empty (is $CLAUDE_CODE_SESSION_ID set?)")
    # terminal-notifier gives the GOOD banners (named source, click→focus, per-lead coalescing).
    # Without it, iTerm leads still get click-to-focus for free (the Stop hook's tier-1 path writes
    # the notification straight to this session's own tty via OSC 777 — see _notify in
    # hooks/stop_lead_watch.py) — just no coalescing (repeated wakes stack instead of replacing).
    # Terminal.app leads have no such fallback: without terminal-notifier they get the fully
    # degraded osascript banner (not clickable at all). PATH-robust check (find_terminal_notifier
    # probes brew dirs too) so we don't falsely warn.
    if lead_guard.load_config(STATE_ROOT).get("notify_on_wake", True) \
            and not lead_guard.find_terminal_notifier():
        if iterm.NAME == "iterm" and os.environ.get("TERM_SESSION_ID"):
            print("NOTE: terminal-notifier not found — desktop banners use iTerm's native "
                  "click-to-focus\ninstead (no per-lead coalescing: repeated wakes stack rather "
                  "than replace). For that too:\n  brew install terminal-notifier", file=sys.stderr)
        else:
            print("WARNING: terminal-notifier not found — desktop banners fall back to macOS's built-in\n"
                  "notifications (not clickable, no per-lead coalescing). For click-to-focus banners:\n"
                  "  brew install terminal-notifier", file=sys.stderr)
    # The project name identifies this lead's work in `relay list` and restore; defaults to the
    # working-directory basename when not named explicitly. cwd is where a restored lead reopens.
    cwd = os.getcwd()
    project = getattr(args, "project", None) or os.path.basename(cwd)
    # Re-arm (e.g. the successor's post-handoff /relay:mode verify) must not clobber handoff/history
    # state that only the FIRST arm ever sets: `predecessor` (cmd_handoff pre-arms it before this
    # ever runs) and `started` (should reflect when the lead actually began, not each re-verify).
    # Read it now (rather than at write_marker time below) so its `predecessor` can also feed the
    # name-uniqueness exclusion: a handoff successor inherits its predecessor's name on purpose.
    existing = lead_guard.read_marker(STATE_ROOT, args.session_id)
    pred_sid = (existing.get("predecessor") or {}).get("session_id")
    resolved_project, clash_sid = unique_lead_project(
        project, args.session_id, [pred_sid] if pred_sid else [], lead_guard.list_leads(STATE_ROOT))
    if resolved_project != project:
        print(f"NOTE: '{project}' is taken by a live lead ({(clash_sid or '?')[:8]}) — armed as "
              f"'{resolved_project}' instead.", file=sys.stderr)
    project = resolved_project
    iterm_session = os.environ.get("TERM_SESSION_ID")  # the lead's own iTerm session ("w#t#p#:UUID")
    # Give the lead tab a stable, relay-controlled title (like executors get) so `relay focus <lead>`
    # and notification click-through can land on it. Rename via /rename into the lead's OWN session,
    # matched by its iTerm id. Best-effort — if it doesn't take, focus just won't find the lead tab.
    tab_label = f"[Lead] {slugify(project)}"
    if not getattr(args, "no_rename", False):
        iterm.rename_by_id(iterm_session, tab_label)
    # Stable per-lead tab color; this lead's executors inherit it at spawn so its tabs group
    # visually. Paint the lead's OWN tab by writing the escape to its tty (found via the session
    # id — this CLI process has no controlling terminal, so /dev/tty is unavailable). iTerm only.
    cfg = lead_guard.load_config(STATE_ROOT)
    color = lead_guard.pick_lead_color(STATE_ROOT, args.session_id) if cfg.get("tab_colors", True) else None
    if color and getattr(iterm, "NAME", "") == "iterm" and not getattr(args, "no_rename", False):
        tty = iterm.tty_by_id(iterm_session)
        if tty:
            try:
                with open(tty, "w") as f:
                    f.write(iterm.tab_color_escape(color))
            except OSError:
                pass  # cosmetic — never block arming on a paint failure
    lead_guard.write_marker(STATE_ROOT, args.session_id, model=args.model,
                            iterm_session=iterm_session, project=project, cwd=cwd,
                            tab_label=tab_label, color=color,
                            plugin_version=plugin_version(), stop_hook_timeout=stop_hook_timeout(),
                            predecessor=existing.get("predecessor"), started=existing.get("started"),
                            # Autonomous posture (§6f, #16 phase 1) is stamped FRESH on every arm from
                            # config — deliberately NOT preserved like predecessor/started. Arming is
                            # the reset point: you opt into auto for a plan you're confident about, and
                            # a re-arm puts the posture back to the account-wide default (False unless
                            # `autonomous_mode: true`) rather than letting it silently outlive its plan.
                            autonomous=cfg.get("autonomous_mode", False),
                            autonomous_source="config",
                            backend=iterm.NAME)  # which terminal app THIS lead-start ran under (D2,
                                                # wake-watch design "cross-backend nudge" fix) — the
                                                # same field/values cmd_spawn already writes for
                                                # executors (bin/relay:612), so term_backend() reads
                                                # either uniformly instead of guessing ambient
    # Record the cwd's current git HEAD as the baseline, so the Stop-hook commit-surfacing (App 2)
    # only reports commits made AFTER lead mode began — not the repo's entire prior history.
    lead_guard.write_head(STATE_ROOT, args.session_id, lead_guard.git_head(os.getcwd()))
    auto_on = bool(cfg.get("autonomous_mode", False))
    append_ledger("lead_started", session_id=args.session_id, model=args.model, autonomous=auto_on)
    print(f"lead mode active for session '{args.session_id}'"
          + (f" (model {args.model})" if args.model else ""))
    # A lead that armed straight into auto must SAY so — an unannounced inverted posture is exactly
    # the silent-autonomy failure §6f warns against. (Manual is the default and needs no announcement.)
    if auto_on:
        print("AUTONOMOUS MODE ON (config autonomous_mode: true) — this lead proceeds by default on "
              "routine in-plan steps instead of waiting. `relay auto off` reverts it for this session.")


def cmd_handoff(args):
    """One-command lead succession: spawn a successor lead tab PRE-ARMED (its marker written for a
    pinned session id before its first turn — same trick `cmd_spawn` already uses to pin an
    executor's Claude session id via `session_uuid`), seeded with a SHORT POINTER at a relay-owned
    copy of the outgoing lead's handoff file (the copy has a SUCCESSOR AFTERCARE section appended,
    build_packet-style — see build_handoff_copy), then step the outgoing lead down as the final
    act. Its gate + auto-wake are active from turn one; the aftercare section tells the successor to
    run /relay:mode after settling only to VERIFY the pin held (idempotent), not to arm from
    scratch (mirrors cmd_resume_lead's nudge), and names the predecessor-tab-close flow (`relay
    close-predecessor`, only on user go). LIVE-INCIDENT FIX: an earlier revision inlined that whole
    aftercare block (with the pinned UUID twice) directly into the seed prompt — the typed launch
    command truncated mid-string on a real run, corrupting the shell. build_pointer_message's
    fragility rule (short pointer, content lives in a file) applies here too now. Inherited
    executors re-parent automatically on the successor's first send/resume (adopt-on-claim) —
    nothing to wire here."""
    caller = os.environ.get("CLAUDE_CODE_SESSION_ID")
    if not caller or not lead_guard.is_lead(STATE_ROOT, caller):
        sys.exit("handoff: caller isn't an armed lead — run /relay:mode first")
    handoff_path = Path(args.handoff_md).expanduser().resolve()
    if not handoff_path.is_file() or handoff_path.stat().st_size == 0:
        sys.exit(f"handoff: '{args.handoff_md}' doesn't exist or is empty — write the handoff "
                 f"summary (what's in flight, what's reviewed/committed, open questions, next "
                 f"steps) first, then hand off.")

    caller_marker = lead_guard.read_marker(STATE_ROOT, caller)
    project = args.project or caller_marker.get("project") or os.path.basename(os.getcwd())
    cwd = caller_marker.get("cwd") or os.getcwd()
    model = args.model or caller_marker.get("model")
    successor_sid = str(uuid.uuid4())  # pinned — this IS the successor's session id
    tab_label = f"[Lead] {slugify(project)}"
    cfg = lead_guard.load_config(STATE_ROOT)
    color = lead_guard.pick_lead_color(STATE_ROOT, successor_sid) if cfg.get("tab_colors", True) else None
    # Record the predecessor NOW, while its marker is still readable — by the time the successor
    # gets around to acting on it, `clear_lead(caller)` below will have deleted it, so this is the
    # only place this information can be captured.
    predecessor = {"session_id": caller, "tab_label": caller_marker.get("tab_label"),
                   "iterm_session": caller_marker.get("iterm_session")}

    # When this successor began. Captured ONCE and passed to both marker writes below: the pre-arm
    # and the post-spawn refresh are two writes of one lead, and letting the second re-default
    # `started` to its own now() would make the field mean "when the tab finished opening".
    successor_started = now()

    # PRE-ARM: write the successor's marker BEFORE it ever runs a turn, so its gate + auto-wake are
    # live from the moment the tab opens — no /relay:mode needed. Stamping matches cmd_lead_start
    # except for the fields that are not knowable yet or not applicable:
    #   iterm_session — the tab doesn't exist yet; the post-spawn refresh below fills it in.
    #   backend       — knowable NOW: `iterm.spawn` below opens the successor's tab under THIS
    #                   invocation's backend, so it is recorded rather than left for
    #                   _probe_backend_for_tab to guess at the first cross-backend nudge (§1).
    #   autonomous    — False/"config", never inherited from the outgoing lead: §6f makes the
    #                   posture per-session and opt-in-each-time, and a successor arming silently
    #                   into auto because its predecessor happened to be in auto is exactly the
    #                   unannounced inversion §6f warns against. The successor's aftercare
    #                   /relay:mode re-arm applies the `autonomous_mode` config and announces it.
    lead_guard.write_marker(STATE_ROOT, successor_sid, model=model, project=project, cwd=cwd,
                            tab_label=tab_label, color=color,
                            plugin_version=plugin_version(), stop_hook_timeout=stop_hook_timeout(),
                            predecessor=predecessor, started=successor_started,
                            backend=iterm.NAME,
                            autonomous=False, autonomous_source="config")
    lead_guard.write_head(STATE_ROOT, successor_sid, lead_guard.git_head(cwd))

    # d4 linter: the doc THIS caller itself inherited (if it was ever a successor) is the predecessor
    # doc in the lineage; warn on any `[discipline]` marker it carried that the doc being handed
    # onward has dropped (same warning-stamp style as cmd_list's stale-hooks check, §10). A first-ever
    # lead (no inherited copy) has nothing to compare against — dropped_discipline_markers no-ops.
    new_body = handoff_path.read_text()
    inherited_copy_path = lead_guard.lead_dir(STATE_ROOT, caller) / "handoff.md"
    inherited_body = inherited_copy_path.read_text() if inherited_copy_path.is_file() else ""
    dropped = dropped_discipline_markers(inherited_body, new_body)
    if dropped:
        print(c(f"  ⚠ discipline markers dropped: {', '.join(dropped)} — present in the doc you "
                f"inherited but missing from the doc you're handing off. If still true, carry them "
                f"forward verbatim.", "red"))

    # Relay-owned copy of the handoff file, aftercare appended — see build_handoff_copy. The user's
    # source md is never modified (same relationship as packet source → packets/NNN-packet.md).
    # Writing it is treated exactly like a failed spawn below: it must NOT leave the pre-written
    # successor marker behind as an unreachable ghost, and must NOT step the caller down.
    handoff_copy_path = lead_guard.lead_dir(STATE_ROOT, successor_sid) / "handoff.md"
    try:
        handoff_copy_path.write_text(build_handoff_copy(new_body, successor_sid))
    except Exception as e:
        lead_guard.clear_lead(STATE_ROOT, successor_sid)  # best-effort — drop the pre-written ghost
        sys.exit(f"handoff: failed to write successor's handoff copy ({e}) — this session remains "
                 f"lead; nothing was stepped down.")

    # SHORT POINTER ONLY — see build_pointer_message's fragility rule and cmd_handoff's docstring:
    # a prior revision inlined the full aftercare (with the pinned UUID twice) here and the typed
    # launch command truncated mid-seed on a real run, corrupting the shell.
    seed = (f"You are the successor lead for project '{project}', pre-armed by relay handoff. Read "
            f"{handoff_copy_path} and follow its SUCCESSOR AFTERCARE section before anything else.")

    # never leave the project leadless; never leave a ghost on failure: a failed spawn must NOT
    # step the caller down (it's still the only live lead), and must NOT leave the successor's
    # pre-written marker behind as an unreachable ghost.
    skip_perms = bool(cfg.get("executor_skip_permissions", False))
    successor_pid = lead_guard.lead_dir(STATE_ROOT, successor_sid) / "pid"
    iterm_id_file = lead_guard.lead_dir(STATE_ROOT, successor_sid) / "iterm_id"
    try:
        iterm.spawn(
            cwd=cwd,
            prompt=seed,
            label=tab_label,
            pidfile=str(successor_pid),
            model=model,
            skip_perms=skip_perms,
            session_uuid=successor_sid,
            tab_color=color,
            iterm_id_file=str(iterm_id_file),
        )
    except Exception as e:
        lead_guard.clear_lead(STATE_ROOT, successor_sid)  # best-effort — drop the pre-written ghost
        sys.exit(f"handoff: failed to spawn successor tab ({e}) — this session remains lead; "
                 f"nothing was stepped down.")

    iterm_session = read_iterm_id_at(iterm_id_file)  # best-effort; None on timeout is non-fatal
    # Refresh with the now-known iterm_session. Every other field must be re-passed identically to
    # the pre-arm above — write_marker rewrites the WHOLE marker, so anything omitted here would be
    # dropped from a marker that was already correct seconds ago (§1).
    lead_guard.write_marker(STATE_ROOT, successor_sid, model=model, project=project, cwd=cwd,
                            tab_label=tab_label, color=color, iterm_session=iterm_session,
                            plugin_version=plugin_version(), stop_hook_timeout=stop_hook_timeout(),
                            predecessor=predecessor, started=successor_started,
                            backend=iterm.NAME,
                            autonomous=False, autonomous_source="config")

    # Step the caller down — the FINAL act, only after the spawn call has returned successfully.
    lead_guard.clear_lead(STATE_ROOT, caller)
    append_ledger("lead_handoff", from_lead=caller, to_lead=successor_sid, project=project,
                  handoff_md=str(handoff_path))
    print(f"handoff complete — successor lead '{project}' (session {successor_sid}) opened, "
          f"pre-armed; this session has stepped down (gate + auto-wake off here).")


def cmd_close_predecessor(args):
    """Close the zombie tab a handoff leaves behind: the outgoing lead steps down (its marker is
    deleted) but its iTerm tab stays open with nothing on disk pointing at it. cmd_handoff records
    that tab's identity in the successor's OWN marker (`predecessor`) before the old marker is gone
    — this reads it back, closes the tab, and clears the field so the offer can't repeat. Never
    invoked automatically; the successor's seed prompt asks the user first."""
    caller = os.environ.get("CLAUDE_CODE_SESSION_ID")
    if not caller or not lead_guard.is_lead(STATE_ROOT, caller):
        sys.exit("close-predecessor: caller isn't an armed lead — run /relay:mode first")
    marker = lead_guard.read_marker(STATE_ROOT, caller)
    pred = marker.get("predecessor") or {}
    if not pred:
        print("close-predecessor: no predecessor recorded for this lead — nothing to close.")
        return
    pred_sid = pred.get("session_id")
    if pred_sid and lead_guard.is_lead(STATE_ROOT, pred_sid):
        sys.exit(f"close-predecessor: predecessor {pred_sid[:8]}… is still an armed lead — not "
                 f"closing a live lead's tab; ask them to /relay:stop first.")
    # Kill the predecessor's claude process BEFORE closing the tab — iTerm's `close` docstring:
    # without this, iTerm pops a 'confirm close running process' dialog that blocks osascript.
    # There's no recorded pid for a lead (unlike executors), so find it live via the tab's tty.
    # Best-effort throughout: a lookup miss at any step still falls through to attempting the close.
    pred_tty = iterm.tty_by_id(pred.get("iterm_session")) if pred.get("iterm_session") else None
    pred_pid = iterm.pid_on_tty(pred_tty) if pred_tty else None
    if pred_pid:
        try:
            os.kill(pred_pid, signal.SIGTERM)
            time.sleep(0.3)
        except Exception:
            pass
    closed = iterm.close(pred.get("tab_label") or "", pred.get("iterm_session"), None)
    if closed:
        tab_note = "closed its tab"
    elif not iterm.is_alive(pred.get("tab_label") or "", pred.get("iterm_session")):
        tab_note = "tab closed itself"
    else:
        tab_note = "tab not auto-closed — Cmd-W it if it lingers"
    marker.pop("predecessor", None)
    lead_guard.marker_path(STATE_ROOT, caller).write_text(json.dumps(marker, indent=2))
    append_ledger("predecessor_closed", session_id=caller, predecessor=pred_sid, tab_closed=bool(closed))
    print(f"close-predecessor: predecessor {pred_sid[:8] if pred_sid else '?'}… — {tab_note}")


def cmd_route(args):
    """The retain escape hatch (invoked by /relay:route). When a legit lead-appropriate edit gets
    gated, this opens a short grace window during which edits pass, and logs one durable `retained`
    event to the shared ledger."""
    if not args.session:
        sys.exit("route: session id is empty (is $CLAUDE_CODE_SESSION_ID set?)")
    if not lead_guard.is_lead(STATE_ROOT, args.session):
        sys.exit(f"route: session '{args.session}' is not in lead mode — run /relay:mode first")
    cfg = lead_guard.load_config(STATE_ROOT)
    lead_guard.set_grace(STATE_ROOT, args.session, cfg["grace_seconds"])
    append_ledger("retained", session_id=args.session, reason=args.reason)
    print(f"retain window open for {cfg['grace_seconds']}s — reason: {args.reason}")


def cmd_auto(args):
    """`relay auto on|off|status` (invoked by /relay:auto) — the lead's AUTONOMOUS POSTURE toggle
    (§6f, task #16 phase 1). It does not change what the lead is allowed to do; it changes the
    DEFAULT: manual = wait for the human on every routine in-plan approval beat, auto = proceed on
    those and announce afterwards. The judgement calls (the stop-list in skills/mode/SKILL.md) stop
    either way, and committing executor work ALWAYS stops for the human in phase 1 — auto-commit
    waits on the #7 verifier.

    State lives in the lead's own marker, so it is per-session and resets to the `autonomous_mode`
    config value on every fresh arm: you opt in when you're confident about THIS plan, rather than a
    posture silently outliving the plan it was scoped to. `status` is read-only (no ledger event);
    `on`/`off` each log one durable ledger event, because "the human wasn't asked" must still be
    reconstructable afterwards."""
    if not args.session:
        sys.exit("auto: session id is empty (is $CLAUDE_CODE_SESSION_ID set?)")
    if not lead_guard.is_lead(STATE_ROOT, args.session):
        sys.exit(f"auto: session '{args.session}' is not in lead mode — run /relay:mode first")
    marker = lead_guard.read_marker(STATE_ROOT, args.session)
    on, source = lead_guard.autonomous_state(marker)
    project = marker.get("project") or args.session

    if args.action == "status":
        origin = ("set by `relay auto` this session" if source == "command"
                  else f"from config autonomous_mode: {json.dumps(bool(on))}")
        if on:
            print(f"autonomous mode is ON for lead '{project}' ({origin}) — proceeding by default on "
                  f"routine in-plan steps; the stop-list still stops, and committing executor work "
                  f"always waits for you.")
        else:
            print(f"autonomous mode is OFF for lead '{project}' ({origin}) — waiting for you on "
                  f"every approval beat. `relay auto on` flips it for this session.")
        return

    want = (args.action == "on")
    if not lead_guard.set_autonomous(STATE_ROOT, args.session, want):
        sys.exit(f"auto: no lead marker for '{args.session}' — run /relay:mode first")
    append_ledger("auto_mode_on" if want else "auto_mode_off", session_id=args.session,
                  project=marker.get("project"), was=on)
    if want:
        print(f"autonomous mode ON for lead '{project}' — proceed by default WITHIN the approved "
              f"plan; announce every autonomous action with what would have been asked. Still stops: "
              f"risk-flagged/failing/UNVERIFIED reports, core logic/ledgers/parity/migrations/deploys, "
              f"irreversible or outward-facing actions, work not in the plan, genuine ambiguity — and "
              f"COMMITTING executor work always stops for the human. `relay auto off` reverts; a fresh "
              f"`/relay:mode` arm resets to config.")
    else:
        print(f"autonomous mode OFF for lead '{project}' — back to announce-and-wait on every "
              f"approval beat.")


def cmd_focus(args):
    """Jump to a session's iTerm tab via a bounded title match on its relay label — the reliable
    ccsessions mechanism (activate + select window + select tab). Works for executors AND leads:
    both get a stable relay-controlled tab title (executors at spawn, leads at /relay:mode)."""
    sid = args.session_id
    s = read_session(sid)
    if s:
        if term_backend(s).focus(s.get("tab_label", ""), s.get("iterm_session"), s.get("pid")):
            print(f"focused '{sid}' (tab '{s.get('tab_label')}')")
            return
        sys.exit(
            f"could not focus '{sid}' — no live iTerm tab matched its label '{s.get('tab_label')}'. "
            f"If its tab is closed, bring it back: `relay resume {sid}` (keeps context + staged work) "
            f"or `relay restart {sid}` (re-runs its packet fresh).")
    marker = lead_guard.read_marker(STATE_ROOT, sid)  # a lead session?
    if marker:
        # Identity first, exactly like the executor branch above: the marker's recorded backend and
        # handle, not the label alone. Two leads can share a tab title (a handoff pair does, byte
        # for byte — backlog §2), so a label-only focus could jump to the OTHER lead's tab.
        bk, label, handle = _lead_tab_target(marker)
        if label and bk.focus(label, handle):
            print(f"focused lead '{marker.get('project')}' (tab '{label}')")
            return
        sys.exit(
            f"could not focus lead '{sid}' — no live tab matched '{label}'. The lead tab is renamed at "
            f"/relay:mode; if it wasn't (or was renamed since), re-run /relay:mode to reset it.")
    sys.exit(f"no such session: {sid}")


def _probe_backend_for_tab(label, handle):
    """When a lead's marker has no recorded `backend` (armed before D2, or a pre-D2 packet), don't
    fall back to the CALLER's ambient guess (backend.select() — exactly the bug: an executor
    running in Terminal.app selecting the `terminal` backend to address an iTerm-hosted lead, see
    Defect A). Instead probe every known backend's `is_alive(label, handle)` and use whichever one
    actually has the tab. Returns the backend module if EXACTLY one has it; None if zero or more
    than one matched (ambiguous — caller falls back to the ambient guess, same as before this
    existed). Never raises; a backend whose probe itself errors is just skipped."""
    found = []
    for name in ("iterm", "terminal"):
        bk = backend.by_name(name)
        try:
            if bk and label and bk.is_alive(label, handle):
                found.append(bk)
        except Exception:
            continue
    return found[0] if len(found) == 1 else None


def _lead_tab_target(marker):
    """How to address a LEAD's own tab: `(backend, label, handle)`.

    Two identities, both from the marker rather than from the caller's ambient state:
      - the BACKEND that hosts the tab (recorded at arm time; probed, not guessed, for markers
        armed before backend stamping existed — see _probe_backend_for_tab);
      - the HANDLE ($TERM_SESSION_ID) that identifies the tab WITHIN that backend, which every
        tab op takes as its id-first argument and which callers used to simply not pass.
    Leaving the handle out makes an operation label-aware, and lead labels are NOT unique — a
    handoff pair shares `[Lead] <project>` byte-for-byte (backlog §2), so a label-only lookup can
    answer about, focus, or act on the WRONG lead's tab. The handle is already on the marker; this
    exists so no lead-tab call site has to remember to pass it.

    NOTE: cmd_nudge_lead below resolves the backend with this same logic inline. It is deliberately
    NOT refactored onto this helper here — the packet that added this helper was explicitly bounded
    off the wake path, and nudge-lead IS that path. Fold it in as a follow-up (behavior-identical),
    rather than letting the two drift."""
    label = marker.get("tab_label")
    handle = marker.get("iterm_session")
    recorded = marker.get("backend")
    if recorded:
        bk = backend.by_name(recorded) or iterm
    else:
        bk = _probe_backend_for_tab(label, handle) or iterm  # last resort: ambient guess, as before
    return bk, label, handle


def cmd_nudge_lead(args):
    """`relay send` pointed at a LEAD's own tab instead of an executor's (wake-watch design §9) —
    the push primitive the executor-side escalation hook calls to wake an idle lead. ALWAYS sends,
    unconditionally — §9.5b spiked this directly: typing into a busy lead is harmless (it queues in
    the input box and is processed intact at turn-end), so there is no busy/stale guard here any
    more. The only refusal left is a dead tab.

    Sends via the marker's OWN recorded backend (`term_backend`), never the caller's ambient guess
    — Defect A, live-reproduced: an executor running under Terminal.app selects the `terminal`
    backend for ITSELF, and used to hand that same wrong backend to an iTerm-hosted lead, which
    can't inject text at all (terminal_app.send is unconditionally False by design — see its
    docstring), so every cross-backend nudge silently "found no live tab" even though the lead's tab
    was right there. A marker with no recorded backend (every lead armed before D2) gets probed
    (_probe_backend_for_tab) rather than guessed."""
    sid = args.lead
    marker = lead_guard.read_marker(STATE_ROOT, sid)
    if not marker:
        sys.exit(f"no such lead: {sid}")

    label = marker.get("tab_label")
    handle = marker.get("iterm_session")
    recorded = marker.get("backend")
    if recorded:
        bk = backend.by_name(recorded) or iterm
    else:
        bk = _probe_backend_for_tab(label, handle) or iterm  # last resort: ambient guess, as before
    try:
        ok = bool(label) and bk.send(label, args.message, handle)
    except Exception:
        ok = False
    if not ok:
        # A dead tab and a live-but-uninjectable one are DIFFERENT failures and must not report the
        # same way: terminal_app.send is unconditionally False by design (Terminal.app cannot inject
        # text into a running process), so a healthy Terminal-hosted lead would otherwise be reported
        # as "no live tab" — the exact silent-failure/indistinguishable-cause pattern §9.6a exists to
        # kill. Probe liveness to tell them apart before refusing.
        alive = False
        try:
            alive = bool(label) and bk.is_alive(label, handle)
        except Exception:
            alive = False
        if alive:
            sys.exit(f"cannot-inject: lead '{sid}' tab '{label}' is ALIVE, but backend "
                     f"'{getattr(bk, 'NAME', '?')}' cannot type into a running process. The push is "
                     f"unavailable here; the lead still surfaces reports via its own at-Stop check "
                     f"and the desktop notification.")
        sys.exit(f"no-live-tab: could not find a live tab for lead '{sid}' (label '{label}').")

    print(f"nudged: sent message to idle lead '{sid}' (tab '{label}')")


def _resolve_whoami(token):
    """Resolve ANY of: a lead's session id, an executor's relay NAME, or an executor's
    `claude_session` uuid to (role, name, record) — `role` is "lead"|"executor", `name` is the
    canonical relay identifier (the lead's session id, or the executor's relay name — NOT its
    claude_session uuid), `record` is the marker dict (lead) or session.json dict (executor).
    (None, None, None) if the token matches nothing. Read-only — no new state, no reverse index
    (Boundaries): the uuid case is a linear scan over existing session.json files, same cost class
    as every other multi-session bin/relay command (cmd_list, cmd_check --all, ...)."""
    marker = lead_guard.read_marker(STATE_ROOT, token)
    if marker:
        return "lead", token, marker
    s = read_session(token)
    if s:
        return "executor", token, s
    for name in all_session_ids():
        s = read_session(name)
        if s and s.get("claude_session") == token:
            return "executor", name, s
    return None, None, None


def cmd_whoami(args):
    """`relay whoami [<token>]` — a session asking relay "who am I, and who is my lead" through a
    command instead of poking at ~/.relay-tasks JSON by hand. `<token>` may be a lead's session id,
    an executor's relay name, or an executor's claude_session uuid; omitted, it falls back to
    $CLAUDE_CODE_SESSION_ID (an executor's own shell has that set to its claude_session; a lead's,
    to its session id directly). --json is the machine contract hooks/executor_escalation.py (D5)
    consumes instead of reading session.json/report paths itself."""
    token = args.token or os.environ.get("CLAUDE_CODE_SESSION_ID")
    if not token:
        sys.exit("whoami: no token given and $CLAUDE_CODE_SESSION_ID is not set")

    role, name, record = _resolve_whoami(token)
    if role is None:
        sys.exit(f"whoami: could not resolve '{token}' to a known executor or lead")

    if role == "lead":
        execs = []
        for eid in all_session_ids():
            s = read_session(eid)
            if s and s.get("owner_lead") == name:
                execs.append({"name": s.get("session_id"), "status": s.get("status")})
        data = {
            "name": record.get("project") or name,
            "session": name,
            "role": "lead",
            "backend": record.get("backend"),
            "tab_label": record.get("tab_label"),
            "iterm_session": record.get("iterm_session"),
            "execs": execs,
        }
        if getattr(args, "json", False):
            print(json.dumps(data, indent=2))
        else:
            print(f"name       : {data['name']}")
            print(f"session    : {data['session']}")
            print("role       : lead")
            print(f"backend    : {data['backend'] or '-'}             tab '{data['tab_label'] or '-'}'")
            exs = ", ".join(f"{e['name']} ({e['status']})" for e in execs) if execs else "-"
            print(f"execs      : {exs}")
        return

    # role == "executor"
    n = int(record.get("current_packet", 1))
    report_path = str(packets_dir(name) / f"{n:03d}-report.md")
    owner_lead = record.get("owner_lead")
    owner_marker = lead_guard.read_marker(STATE_ROOT, owner_lead) if owner_lead else {}
    data = {
        "name": name,
        "session": record.get("claude_session"),
        "role": "executor",
        "status": record.get("status"),
        "owner_lead": owner_lead,
        "current_packet": n,
        "report_path": report_path,
        "report_exists": os.path.exists(report_path),
        "lead_backend": owner_marker.get("backend"),
        "lead_tab_label": owner_marker.get("tab_label"),
        "lead_iterm_session": owner_marker.get("iterm_session"),
    }
    if getattr(args, "json", False):
        print(json.dumps(data, indent=2))
    else:
        print(f"name       : {data['name']}")
        print(f"session    : {data['session']}")
        print("role       : executor")
        print(f"status     : {data['status']}          (packet {n:03d})")
        if owner_lead:
            print(f"lead       : {owner_lead}  {owner_marker.get('project') or '-'}  "
                  f"[{data['lead_backend'] or '?'}]  tab '{data['lead_tab_label'] or '-'}'")
        else:
            print("lead       : -  (unowned)")


def _sid_candidates_message(token, sids, purpose):
    """Render resolve_sid's ambiguous-token exit message: every candidate sid, newest-first by
    activity, alongside whatever identifying context distinguishes it (a lead's project + plugin
    version, or an executor's topic) — so the caller can tell them apart without the resolver
    guessing on their behalf."""
    rows = []
    for sid in sids:
        marker = lead_guard.read_marker(STATE_ROOT, sid)
        if marker:
            ts = marker.get("last_active") or ""
            desc = (f"lead '{marker.get('project') or '-'}', v{marker.get('plugin_version') or '?'}, "
                    f"{_relative_age(ts)}")
        else:
            s = read_session(sid) or {}
            ts = s.get("updated") or ""
            desc = f"executor '{s.get('topic') or '-'}', {_relative_age(ts)}"
        rows.append((ts, sid, desc))
    rows.sort(key=lambda r: r[0], reverse=True)
    lines = "\n".join(f"  {sid}  ({desc})" for _, sid, desc in rows)
    return (f"ambiguous {purpose} '{token}' — matches multiple sessions:\n{lines}\n"
            f"pass the session id (or a unique prefix of it) instead")


def resolve_sid(token, purpose="session"):
    """The ONE name-resolution surface every sid-accepting relay command/flag routes through
    (wired centrally in main()'s RESOLVE_FIELDS loop) — lets a human type an executor's name
    (already its id, set via `spawn --name`), a lead's project name, or a unique prefix of either's
    id, anywhere a raw session id was previously required.

    Resolution order (first hit wins, deterministic):
      a) exact executor session id (a top-level session dir with session.json) — existing behavior,
         unchanged, highest precedence.
      b) exact lead session id (a marker exists for it).
      c) lead PROJECT NAME — case-sensitive exact match on marker["project"] across
         lead_guard.list_leads(). Exactly one match wins; more than one (e.g. an old + new lead of
         the same project after a handoff) exits via _sid_candidates_message — NEVER guessed.
      d) a unique prefix (len >= 6) of any known sid (executor ids ∪ lead ids). Multiple matches
         get the same candidates-listing exit as (c).
      e) no match at all → the token is returned UNCHANGED. Each command's own "no such session"
         error remains the single source of not-found messaging; this resolver never invents new
         failure text for a genuine miss.

    Read-only (never writes) and defensive: any exception while scanning degrades to returning the
    token unchanged — a resolver bug must never be the reason a previously-working raw sid stops
    working."""
    if not token:
        return token
    try:
        if read_session(token) is not None:
            return token
        if lead_guard.read_marker(STATE_ROOT, token):
            return token

        leads = lead_guard.list_leads(STATE_ROOT)
        project_matches = [m["session_id"] for m in leads
                            if m.get("project") == token and m.get("session_id")]
        if len(project_matches) == 1:
            return project_matches[0]
        if len(project_matches) > 1:
            sys.exit(_sid_candidates_message(token, project_matches, purpose))

        if len(token) >= 6:
            all_ids = set(all_session_ids()) | {m.get("session_id") for m in leads if m.get("session_id")}
            prefix_matches = sorted(sid for sid in all_ids if sid.startswith(token))
            if len(prefix_matches) == 1:
                return prefix_matches[0]
            if len(prefix_matches) > 1:
                sys.exit(_sid_candidates_message(token, prefix_matches, purpose))

        return token
    except SystemExit:
        raise
    except Exception:
        return token


def main():
    p = argparse.ArgumentParser(prog="relay")
    sub = p.add_subparsers(dest="cmd", required=True)

    sp = sub.add_parser("spawn")
    sp.add_argument("worktree")
    sp.add_argument("topic")
    sp.add_argument("packet")
    sp.add_argument("--model")
    sp.add_argument("--model-override", metavar="REASON",
                    help="required to spawn a model above executor_model_ceiling — the reason is "
                    "recorded in the ledger (model_ceiling_override)")
    sp.add_argument("--name")
    sp.add_argument("--scope")
    sp.add_argument("--lead", help="session id of the lead spawning this executor (stamps ownership); "
                    "defaults to $CLAUDE_CODE_SESSION_ID, else unowned")
    # Tri-state: neither flag → None → use config's executor_skip_permissions. --skip-perms forces
    # on for this spawn, --no-skip-perms forces off. (store_true/store_false on the same dest.)
    sp.add_argument("--skip-perms", dest="skip_perms", action="store_true", default=None,
                    help="run this executor with --dangerously-skip-permissions (overrides config)")
    sp.add_argument("--no-skip-perms", dest="skip_perms", action="store_false",
                    help="force this executor to prompt for permissions (overrides config)")
    # Tri-state, same pattern as --skip-perms/--no-skip-perms: neither flag → None → use config's
    # executor_layout. --pane forces a split pane in the lead's window (iTerm only, falls back to
    # a tab if the lead's session can't be located); --tab forces a separate tab.
    sp.add_argument("--pane", dest="pane", action="store_true", default=None,
                    help="open this executor as a split pane in the lead's window (overrides config; iTerm only)")
    sp.add_argument("--tab", dest="pane", action="store_false",
                    help="open this executor as a separate tab (overrides config)")
    sp.set_defaults(func=cmd_spawn)

    sd = sub.add_parser("send")
    sd.add_argument("session_id")
    sd.add_argument("packet")
    sd.set_defaults(func=cmd_send)

    ck = sub.add_parser("check")
    ck.add_argument("session_id", nargs="?")
    ck.add_argument("--all", action="store_true")
    ck.add_argument("--json", action="store_true")
    ck.set_defaults(func=cmd_check)

    stt = sub.add_parser("status")
    stt.add_argument("session_id", nargs="?")
    stt.add_argument("--statusline", action="store_true",
                     help="read the session id from a JSON payload on stdin (Claude Code's statusLine hook)")
    stt.set_defaults(func=cmd_status)

    ls = sub.add_parser("list")
    ls.add_argument("--json", action="store_true")
    ls.add_argument("--closed", action="store_true", help="show closed/superseded/dead sessions "
                    "(capped at 15 most recent)")
    ls.add_argument("--lead", help="scope EXECUTORS to this lead's project (its owned executors "
                    "plus unowned ones); LEADS are always shown in full")
    ls.add_argument("--all", action="store_true", help="show every executor regardless of owner "
                    "(the default when --lead is absent)")
    ls.set_defaults(func=cmd_list)

    cl = sub.add_parser("close")
    cl.add_argument("session_id", nargs="?")
    cl.add_argument("--supersede")
    cl.add_argument("--self", dest="self_session", help="step down from lead mode for this session id")
    cl.add_argument("--keep-tab", action="store_true", help="mark closed but leave the iTerm tab open")
    cl.set_defaults(func=cmd_close)

    st = sub.add_parser("stop")
    st.add_argument("session_id")
    st.set_defaults(func=cmd_stop)

    lst = sub.add_parser("lead-start")
    lst.add_argument("session_id")
    lst.add_argument("--model")
    lst.add_argument("--project", help="name this lead's project (defaults to the cwd basename)")
    lst.add_argument("--no-rename", action="store_true", help="don't rename the lead's iTerm tab")
    lst.set_defaults(func=cmd_lead_start)

    ad = sub.add_parser("adopt")
    ad.add_argument("session_id")
    ad.add_argument("--force", action="store_true",
                    help="take ownership even if the current owner is a live lead")
    ad.set_defaults(func=cmd_adopt)

    rt = sub.add_parser("route")
    rt.add_argument("kind", choices=["retain"])
    rt.add_argument("reason")
    rt.add_argument("--session", required=True)
    rt.set_defaults(func=cmd_route)

    at = sub.add_parser("auto", help="autonomous posture for this lead: proceed-by-default on "
                        "routine in-plan steps, or wait for the human (default)")
    at.add_argument("action", choices=["on", "off", "status"])
    at.add_argument("--session", required=True)
    at.set_defaults(func=cmd_auto)

    rpt = sub.add_parser("report")
    rpt.add_argument("session_id")
    rpt.add_argument("--packet", type=int)
    rpt.set_defaults(func=cmd_report)

    df = sub.add_parser("diff")
    df.add_argument("session_id")
    df.add_argument("--open", action="store_true", help="open the generated HTML page after writing it")
    df.add_argument("--all", action="store_true", help="render the whole staged diff, unfiltered "
                    "(default: scoped to files mentioned in the session's current packet report)")
    df.set_defaults(func=cmd_diff)

    fc = sub.add_parser("focus")
    fc.add_argument("session_id")
    fc.set_defaults(func=cmd_focus)

    rs = sub.add_parser("restart")
    rs.add_argument("session_id")
    rs.add_argument("--force", action="store_true", help="restart even if the process still looks alive")
    rs.set_defaults(func=cmd_restart)

    rsm = sub.add_parser("resume")
    rsm.add_argument("session_id")
    rsm.add_argument("--force", action="store_true", help="resume even if the process still looks alive")
    rsm.set_defaults(func=cmd_resume)

    pr = sub.add_parser("prune")
    pr.add_argument("--days", type=int, default=7,
                    help="prune closed/superseded/dead sessions not updated in this many days (default 7)")
    pr.add_argument("--dry-run", action="store_true", help="list what would be pruned without deleting")
    pr.set_defaults(func=cmd_prune)

    hf = sub.add_parser("handoff")
    hf.add_argument("handoff_md", help="path to the handoff summary file")
    hf.add_argument("--project", help="successor's project name (default: caller lead's project, else cwd basename)")
    hf.add_argument("--model", help="successor's model (default: caller lead's marker model)")
    hf.set_defaults(func=cmd_handoff)

    cp = sub.add_parser("close-predecessor")
    cp.set_defaults(func=cmd_close_predecessor)

    nl = sub.add_parser("nudge-lead")
    nl.add_argument("lead")
    nl.add_argument("message")
    nl.set_defaults(func=cmd_nudge_lead)

    wm = sub.add_parser("whoami")
    wm.add_argument("token", nargs="?")
    wm.add_argument("--json", action="store_true")
    wm.set_defaults(func=cmd_whoami)

    el = sub.add_parser("_ensure-label", help=argparse.SUPPRESS)  # internal: see cmd_ensure_label
    el.add_argument("handle")
    el.add_argument("label")
    el.set_defaults(func=cmd_ensure_label)

    args = p.parse_args()

    # Universal name resolution: every sid-accepting positional/flag gets routed through
    # resolve_sid HERE, once, rather than duplicated at the top of every cmd_* — this is the only
    # place a fresh sid surface needs wiring in. Two deliberate exclusions, per resolve_sid's own
    # docstring: `lead-start`'s session_id CREATES the lead namespace (always the raw
    # $CLAUDE_CODE_SESSION_ID, nothing to resolve against yet) and `handoff`'s positional is a path,
    # not a sid — neither appears below. `status`'s positional IS resolved (it's the explicit token
    # a human typed); its stdin/env-derived id is a separate path inside cmd_status itself and never
    # touches this loop, keeping the per-render statusline path scan-free.
    RESOLVE_FIELDS = {
        "send": ["session_id"], "check": ["session_id"], "status": ["session_id"],
        "close": ["session_id", "supersede", "self_session"], "stop": ["session_id"],
        "adopt": ["session_id"], "route": ["session"], "report": ["session_id"],
        "auto": ["session"],
        "diff": ["session_id"], "focus": ["session_id"], "restart": ["session_id"],
        "resume": ["session_id"], "spawn": ["lead"], "list": ["lead"],
        "nudge-lead": ["lead"],
    }
    for field in RESOLVE_FIELDS.get(args.cmd, []):
        val = getattr(args, field, None)
        if val:
            setattr(args, field, resolve_sid(val))

    if args.cmd == "check" and not args.all and not args.session_id:
        sys.exit("specify a session_id or --all")
    args.func(args)


if __name__ == "__main__":
    main()
